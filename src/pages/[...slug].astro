---
import MainLayout from '../layouts/MainLayout.astro';
import { mainMenu, type MenuItem } from '../data/menu';

export function getStaticPaths() {
  const paths: { params: { slug: string } }[] = [];

  function collectPaths(items: MenuItem[], parentPath: string = '') {
    for (const item of items) {
      if (item.href && item.href !== '/') {
        const slug = item.href.replace(/^\//, '');
        paths.push({ params: { slug } });
      }
      if (item.children) {
        collectPaths(item.children, parentPath);
      }
    }
  }

  collectPaths(mainMenu);
  return paths;
}

// Find matching menu item to get its label
const slug = Astro.params.slug;
const slugPath = '/' + (slug || '');
let pageTitle = '';

function findLabel(items: typeof mainMenu, path: string): string {
  for (const item of items) {
    if (item.href === path) return item.label;
    if (item.children) {
      const found = findLabel(item.children, path);
      if (found) return found;
    }
  }
  return '';
}

pageTitle = findLabel(mainMenu, slugPath);

if (!pageTitle && slug) {
  const segments = slug.split('/');
  const lastSegment = segments[segments.length - 1] || '';
  pageTitle = lastSegment
    .split('-')
    .map(w => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');
}

const title = pageTitle || 'Stránka';
---

<MainLayout title={title}>
  <div class="section max-w-2xl py-12">
    <div class="card p-8 text-center">
      <h1 class="text-2xl font-bold text-ink mb-4">
        {title}
      </h1>

      <div class="bg-surface rounded-card p-6 border border-line">
        <p class="text-lg font-semibold text-ink mb-2">
          Obsah sa pripravuje
        </p>
        <p class="text-sm text-muted">
          Táto sekcia bude čoskoro doplnená. Pre aktuálne informácie nás kontaktujte.
        </p>
      </div>

      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href="/" class="btn-secondary text-sm">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          Späť na Domov
        </a>
        <a href="/kontakt/ajuva" class="btn-primary text-sm">
          Kontaktujte nás
        </a>
      </div>
    </div>
  </div>
</MainLayout>
