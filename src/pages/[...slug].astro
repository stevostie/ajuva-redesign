---
import MainLayout from '../layouts/MainLayout.astro';
import { mainMenu, type MenuItem } from '../data/menu';

export function getStaticPaths() {
  const paths: { params: { slug: string } }[] = [];

  function collectPaths(items: MenuItem[], parentPath: string = '') {
    for (const item of items) {
      if (item.href && item.href !== '/') {
        const slug = item.href.replace(/^\//, '');
        paths.push({ params: { slug } });
      }
      if (item.children) {
        collectPaths(item.children, parentPath);
      }
    }
  }

  collectPaths(mainMenu);
  return paths;
}

// Find matching menu item to get its label
const slug = Astro.params.slug;
const slugPath = '/' + (slug || '');
let pageTitle = '';

// Flatten menu to find matching label
function findLabel(items: typeof mainMenu, path: string): string {
  for (const item of items) {
    if (item.href === path) return item.label;
    if (item.children) {
      const found = findLabel(item.children, path);
      if (found) return found;
    }
  }
  return '';
}

pageTitle = findLabel(mainMenu, slugPath);

// If not found, derive from last slug segment
if (!pageTitle && slug) {
  const segments = slug.split('/');
  const lastSegment = segments[segments.length - 1] || '';
  pageTitle = lastSegment
    .split('-')
    .map(w => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');
}

const title = pageTitle || 'Stránka';
---

<MainLayout title={title}>
  <div class="max-w-2xl mx-auto">
    <div class="card-retro p-8 text-center">
      <!-- Header with icon -->
      <div class="text-4xl mb-4">📋</div>

      <h1 class="text-2xl font-bold text-navy mb-4" style="font-family: Georgia, 'Times New Roman', serif;">
        {title}
      </h1>

      <hr class="divider-dots mb-6" />

      <div class="bg-info-retro rounded-lg p-6 border border-navy/20">
        <p class="text-lg text-navy font-bold mb-2">
          Obsah sa pripravuje
        </p>
        <p class="text-sm text-gray-600">
          Táto sekcia bude čoskoro doplnená. Pre aktuálne informácie nás kontaktujte.
        </p>
      </div>

      <!-- Quick links back -->
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href="/" class="inline-block bg-navy text-white px-5 py-2 rounded text-sm font-bold hover:bg-navy-light transition-colors">
          ← Späť na Domov
        </a>
        <a href="/kontakt/ajuva" class="inline-block bg-accent text-navy px-5 py-2 rounded text-sm font-bold hover:bg-accent-light transition-colors">
          Kontaktujte nás
        </a>
      </div>
    </div>
  </div>
</MainLayout>
