---
import MainLayout from '../layouts/MainLayout.astro';
import Gallery from '../components/Gallery.astro';
import ServiceList from '../components/ServiceList.astro';
import ContactCard from '../components/ContactCard.astro';
import Jokes from '../components/Jokes.astro';
import { companyInfo } from '../data/content';
---

<MainLayout>
  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="bg-brand py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <p class="text-accent text-sm font-semibold uppercase tracking-wider">
        Školenia · Prehliadky · BOZP · PO
      </p>
      <h1 class="text-white text-4xl md:text-5xl font-bold leading-tight mt-3">
        Odborné školenia<br class="sm:hidden" /> pre priemysel
      </h1>
      <p class="text-white/70 text-lg mt-4 max-w-2xl mx-auto">
        20 rokov skúseností v oblasti BOZP, revízií a odbornej prípravy
      </p>

      <div class="flex flex-wrap justify-center gap-4 mt-8">
        <a href="/skolenia/kuric-1-5-triedy" class="btn-primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Aktuálne termíny
        </a>
        <a href="/kontakt/ajuva" class="btn-ghost-light">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          Kontaktujte nás
        </a>
      </div>

      <!-- Stats row -->
      <div class="flex flex-wrap justify-center gap-8 md:gap-12 mt-12">
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-white">20+</div>
          <p class="text-white/50 text-sm mt-1">rokov skúseností</p>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-white">3000+</div>
          <p class="text-white/50 text-sm mt-1">vyškolených osôb</p>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-white">10+</div>
          <p class="text-white/50 text-sm mt-1">oblastí služieb</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ TERMÍNY ═══════════════ -->
  <section class="bg-surface">
    <div class="section">
      <h2 class="font-bold text-2xl text-ink">Najbližšie termíny školení</h2>
      <div class="grid md:grid-cols-2 gap-6 mt-8">
        <!-- Card 1: Kurič -->
        <a href="/skolenia/kuric-1-5-triedy" class="card p-6 no-underline block group">
          <span class="inline-block bg-accent/10 text-accent text-xs font-semibold px-2 py-0.5 rounded">Školenie</span>
          <h3 class="font-bold text-lg text-ink mt-3">Kurič I. – V. triedy</h3>
          <p class="text-muted text-sm mt-1.5">Odborná a aktualizačná príprava obslúh VTZ tlakových a plynových</p>
          <p class="flex items-center gap-1.5 mt-3 font-semibold text-brand text-sm">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            21. – 22. 01. 2026
          </p>
          <span class="inline-block mt-2 text-accent font-semibold text-sm group-hover:underline">Viac informácií →</span>
        </a>

        <!-- Card 2: Revízni technici -->
        <a href="/skolenia/kuric-1-5-triedy" class="card p-6 no-underline block group">
          <span class="inline-block bg-brand/10 text-brand text-xs font-semibold px-2 py-0.5 rounded">Školenie</span>
          <h3 class="font-bold text-lg text-ink mt-3">Revízni technici a opravy VTZ</h3>
          <p class="text-muted text-sm mt-1.5">Aktualizačná odborná príprava pre revíznych technikov a osoby na opravy VTZ tlakové a plynové</p>
          <p class="flex items-center gap-1.5 mt-3 font-semibold text-brand text-sm">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Ďalšie termíny v časti Školenia
          </p>
          <span class="inline-block mt-2 text-accent font-semibold text-sm group-hover:underline">Viac informácií →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════ SERVICES + SIDEBAR ═══════════════ -->
  <section class="section">
    <div class="grid md:grid-cols-3 gap-8">
      <!-- LEFT: Services + Gallery + Jokes -->
      <div class="md:col-span-2">
        <h2 class="font-bold text-2xl text-ink mb-6">Čo ponúkame</h2>
        <ServiceList />

        <!-- Gallery -->
        <div class="mt-12">
          <h3 class="font-semibold text-lg text-ink mb-4">Galéria</h3>
          <Gallery />
        </div>

        <!-- Jokes -->
        <div class="mt-12">
          <div class="card">
            <h3 class="font-semibold text-lg text-ink mb-4">Zábava</h3>
            <Jokes />
          </div>
        </div>
      </div>

      <!-- RIGHT: Sidebar -->
      <div class="space-y-6">
        <!-- Aktuálne informácie -->
        <div class="card">
          <p class="text-xs font-semibold text-muted uppercase tracking-wider mb-1">Aktuálne informácie</p>
          <div class="scroll-box" style="height:210px;">
            <div class="scroll-box-inner text-ink text-sm leading-relaxed space-y-4">
              <p>V časti <a href="/skolenia/kuric-1-5-triedy" class="font-semibold text-brand hover:underline">ŠKOLENIA</a> nájdete aktuálne termíny pre odbornú a aktualizačnú odbornú prípravu obslúh VTZ tlakových a plynových.</p>
              <p>Aktuálny termín — <a href="/skolenia/kuric-1-5-triedy" class="font-semibold text-accent hover:underline">21.01 a 22.01.2026</a></p>
              <p>V časti <a href="/skolenia/kuric-1-5-triedy" class="font-semibold text-brand hover:underline">ŠKOLENIA</a> nájdete termíny pre aktualizačnú odbornú prípravu revíznych technikov.</p>
              <p><strong class="text-accent">Pozor!</strong> Od 01.01.2023 sú platné nové ustanovenia zákona č.124/2006 Z.z. Zmeny sú aj v §16.</p>
              <p>Je novelizovaná vyhláška č.356/2007 Z.z. o obsahu a rozsahu vzdelávania (vyhl. č.66/2023).</p>
            </div>
          </div>
        </div>

        <!-- Contact card -->
        <ContactCard />

        <!-- Name day widget -->
        <div class="card text-center text-white" style="background: var(--color-brand); border-color: transparent;">
          <p class="text-xs font-semibold text-white/60 uppercase tracking-wider">Dnes má meniny</p>
          <div id="name-day" class="text-3xl font-bold mt-2">—</div>
          <p class="text-white/40 text-xs mt-1">Slovenský kalendár</p>
          <div class="mx-auto mt-4 mb-4 w-16 h-px bg-white/20"></div>
          <div class="text-white/60 text-xs italic max-w-xs mx-auto leading-relaxed" id="daily-quote"></div>
        </div>

        <!-- Google Maps -->
        <div class="card overflow-hidden !p-0">
          <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2633.304570123456!2d19.1345!3d48.7395!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x471516c5a1b0e5f7%3A0x4a2b1c3d4e5f6789!2sZvolensk%C3%A1%20cesta%2020%2C%20974%2001%20Bansk%C3%A1%20Bystrica!5e0!3m2!1ssk!2ssk!4v1699999999999" width="100%" height="260" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Mapa — AJUVA Banská Bystrica, Zvolenská cesta 20" class="w-full"></iframe>
          <div class="p-4 flex items-center justify-between">
            <div>
              <p class="text-sm font-semibold text-ink">Zvolenská cesta 20, B. Bystrica</p>
              <p class="text-xs text-muted">Parkovanie pri budove</p>
            </div>
            <a href="https://maps.google.com/?q=Zvolenská+cesta+20+Banská+Bystrica" target="_blank" rel="noopener" class="text-accent text-sm font-semibold hover:text-accent-600 transition inline-flex items-center gap-1">Navigovať →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ TRUST BAR ═══════════════ -->
  <section class="bg-surface border-y border-line">
    <div class="section py-12">
      <div class="grid grid-cols-3 text-center">
        <div class="flex flex-col items-center gap-2">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <div class="font-bold text-lg text-ink">20 rokov</div>
          <p class="text-muted text-sm">na trhu</p>
        </div>
        <div class="flex flex-col items-center gap-2">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
          <div class="font-bold text-lg text-ink">Certifikovaní</div>
          <p class="text-muted text-sm">odborníci</p>
        </div>
        <div class="flex flex-col items-center gap-2">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <div class="font-bold text-lg text-ink">Celé</div>
          <p class="text-muted text-sm">Slovensko</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ CTA BANNER ═══════════════ -->
  <section class="bg-brand py-16 text-white text-center">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="font-bold text-2xl md:text-3xl">Máte záujem o spoluprácu?</h2>
      <p class="text-white/70 mt-3 max-w-xl mx-auto">Kontaktujte nás pre nezáväznú konzultáciu.</p>
      <a href="/kontakt/ajuva" class="btn-primary mt-6 inline-flex">
        Kontaktujte nás
      </a>
    </div>
  </section>

  <div class="text-center py-8"><p class="text-xs text-muted">Aktualizované: {companyInfo.lastUpdated}</p></div>

