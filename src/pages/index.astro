      '26.12.': 'Štefan',
      '27.12.': 'Filoména',
      '28.12.': 'Ivana',
      '29.12.': 'Milada',
      '30.12.': 'Dávid',
      '31.12.': 'Silvester',
    };

    const quotes = [
      '"Bezpečnosť nie je produkt, ale proces."',
      '"Dobrý kurič je ten, koho nevidno, ale cítiť teplo."',
      '"Kto je pripravený, nie je prekvapený."',
      '"Najlepší hasič je ten, ktorý nemusel hasiť."',
      '"Vedomosti sú teplo, ktoré nikdy nevyhasne."',
      '"Práca bez BOZP je ako oheň bez komína."',
    ];

    const el = document.getElementById('name-day');
    const quoteEl = document.getElementById('daily-quote');
    if (el && quoteEl) {
      const now = new Date();
      const key = `${now.getDate()}.${now.getMonth() + 1}.`;
      const name = nameDays[key] || '—';
      el.textContent = name;

      // Pick a quote based on day of year
      const dayOfYear = Math.floor((now - new Date(now.getFullYear(), 0, 0)) / 86400000);
      quoteEl.textContent = quotes[dayOfYear % quotes.length] || quotes[0];
    }
  </script>

  <!-- Row 6: Last updated date -->
  <div class="text-center text-sm text-gray-600 mb-4">
    <p class="font-bold">Aktualizované dňa: 29.12.2025</p>
  </div>
</MainLayout>
