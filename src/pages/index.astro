---
import MainLayout from '../layouts/MainLayout.astro';
import Gallery from '../components/Gallery.astro';
import ServiceList from '../components/ServiceList.astro';
import ContactCard from '../components/ContactCard.astro';
import Jokes from '../components/Jokes.astro';
---

<MainLayout>
  <!-- ══════════════════════════════════ HERO ══════════════════════════════════ -->
  <section class="header-gradient text-white py-12 md:py-16 px-4">
    <div class="max-w-6xl mx-auto text-center">
      <h1 class="font-display text-3xl md:text-5xl font-semibold tracking-tight leading-tight">
        Aktuálne termíny školení
      </h1>
      <p class="mt-3 text-base text-white/70 max-w-xl mx-auto">
        Odborná príprava a revízie vyhradených technických zariadení — tlakové, plynové, zdvíhacie
      </p>

      <div class="flex flex-wrap justify-center gap-3 mt-6">
        <a href="/skolenia/kuric-1-5-triedy" class="btn-primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Aktuálne termíny
        </a>
        <a href="/kontakt/ajuva" class="btn-outline-light">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          Kontakt
        </a>
      </div>

      <!-- Alert warning -->
      <div class="alert-warning max-w-2xl mx-auto mt-6 p-4 text-left text-sm">
        <p class="font-semibold text-ink">Pozor — legislatívne zmeny</p>
        <p class="mt-1 text-muted">Od 01.01.2023 sú platné nové ustanovenia zákona č.124/2006 Z.z. (zmeny v §16). Novelizovaná vyhláška č.356/2007 Z.z. vyhl. č.66/2023.</p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════ TERMÍN CARDS ══════════════════════════════════ -->
  <section class="max-w-6xl mx-auto px-4 section-pad">
    <div class="grid md:grid-cols-2 gap-5">
      <div class="card p-6 border-l-[3px] border-l-accent">
        <p class="eyebrow">Školenie</p>
        <h3 class="font-display text-xl font-semibold text-navy-900 mt-1">Kurič I. – V. triedy</h3>
        <p class="text-muted text-sm mt-2 leading-relaxed">Odborná a aktualizačná príprava obslúh vyhradených technických zariadení tlakových a plynových.</p>
        <div class="flex items-center gap-2 mt-3 text-sm font-semibold text-navy-700">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          21.–22.01.2026
        </div>
        <a href="/skolenia/kuric-1-5-triedy" class="inline-flex items-center gap-1 mt-3 text-sm font-semibold text-accent hover:text-accent-600 transition">
          Viac informácií
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>

      <div class="card p-6 border-l-[3px] border-l-accent">
        <p class="eyebrow">Školenie</p>
        <h3 class="font-display text-xl font-semibold text-navy-900 mt-1">Revizní technici a opravy VTZ</h3>
        <p class="text-muted text-sm mt-2 leading-relaxed">Aktualizačná odborná príprava pre revíznych technikov a osoby na opravy VTZ tlakové a plynové.</p>
        <div class="flex items-center gap-2 mt-3 text-sm font-semibold text-navy-700">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Ďalšie termíny v časti ŠKOLENIA
        </div>
        <a href="/skolenia/kuric-1-5-triedy" class="inline-flex items-center gap-1 mt-3 text-sm font-semibold text-accent hover:text-accent-600 transition">
          Viac informácií
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════ BODY: 2-COL GRID ══════════════════════════════════ -->
  <section class="max-w-6xl mx-auto px-4 pb-12">
    <div class="grid md:grid-cols-5 gap-6">
      <!-- LEFT (3/5): Gallery + Services + Jokes -->
      <div class="md:col-span-3 space-y-10">
        <!-- Gallery -->
        <div>
          <p class="eyebrow mb-1">Galéria</p>
          <div class="accent-line mb-4"></div>
          <Gallery />
        </div>

        <!-- Services -->
        <div class="card p-6">
          <p class="eyebrow">Služby</p>
          <div class="accent-line mb-4"></div>
          <h2 class="font-display text-2xl font-semibold text-navy-900 mb-4">
            AJUVA Š+S s.r.o. Vám ponúka
          </h2>
          <ServiceList />
        </div>

        <!-- Jokes -->
        <div class="card p-6">
          <p class="eyebrow">Zábava</p>
          <div class="accent-line mb-4"></div>
          <h2 class="font-sans text-xl font-semibold text-ink mb-3">
            <a href="/zabava/vtipy" class="hover:text-navy-700 transition">Vtipy na tento týždeň</a>
          </h2>
          <Jokes />
        </div>
      </div>

      <!-- RIGHT (2/5): Info + Contact + Name-day + Map -->
      <div class="md:col-span-2 space-y-6">
        <!-- Aktuálne informácie -->
        <div class="card p-5">
          <p class="eyebrow">Aktuálne informácie</p>
          <div class="accent-line mb-4"></div>
          <div class="scroll-box" style="height: 210px;">
            <div class="scroll-box-inner text-sm text-ink leading-relaxed space-y-4">
              <div>
                <p>V časti <a href="/skolenia/kuric-1-5-triedy" class="font-semibold text-navy-700 hover:underline">ŠKOLENIA</a> nájdete ďalšie aktuálne termíny pre odbornú a aktualizačnú odbornú prípravu obslúh vyhradených technických zariadení tlakových a plynových.</p>
                <p class="mt-1 font-semibold text-navy-900">Aktuálny termín: <span class="text-accent">21.01 a 22.01.2026</span></p>
              </div>
              <div>
                <p>V časti <a href="/skolenia/kuric-1-5-triedy" class="font-semibold text-navy-700 hover:underline">ŠKOLENIA</a> nájdete termíny pre aktualizačnú odbornú prípravu revíznych technikov a osoby na opravy VTZ tlakové a plynové.</p>
              </div>
              <div class="alert-warning p-3 text-sm text-ink">
                <p class="font-semibold">Pozor!</p>
                <p class="mt-1 text-muted">Od 01.01.2023 sú platné nové ustanovenia zákona č.124/2006 Z.z. (zmeny v §16). Novelizovaná vyhláška č.356/2007 Z.z. o obsahu a rozsahu vzdelávania vyhl. č.66/2023.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact -->
        <ContactCard />

        <!-- Name day widget -->
        <div class="card p-5 text-center" style="background: linear-gradient(135deg, var(--color-navy-900), var(--color-navy-700)); color: white;">
          <p class="text-xs font-semibold uppercase tracking-wider text-white/60">Dnes má meniny</p>
          <div id="name-day" class="font-display text-2xl font-semibold mt-1">—</div>
          <p class="text-xs text-white/50 mt-1">Slovenský kalendár</p>
          <div class="mt-3 text-xs text-white/70 italic leading-relaxed" id="daily-quote"></div>
        </div>

        <!-- Map -->
        <div class="card overflow-hidden">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2633.304570123456!2d19.1345!3d48.7395!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x471516c5a1b0e5f7%3A0x4a2b1c3d4e5f6789!2sZvolensk%C3%A1%20cesta%2020%2C%20974%2001%20Bansk%C3%A1%20Bystrica!5e0!3m2!1ssk!2ssk!4v1699999999999"
            width="100%"
            height="260"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Mapa — AJUVA, Zvolenská cesta 20, Banská Bystrica"
            class="w-full"
          >
          </iframe>
          <div class="p-3 flex items-center justify-between bg-white">
            <div>
              <p class="text-sm font-semibold text-ink">Zvolenská cesta 20</p>
              <p class="text-xs text-muted">Banská Bystrica</p>
            </div>
            <a
              href="https://maps.google.com/?q=Zvolenská+cesta+20+Banská+Bystrica"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-1 text-sm font-semibold text-accent hover:text-accent-600 transition"
            >
              Navigovať
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════ THANKS + STATS ══════════════════════════════════ -->
  <section class="max-w-6xl mx-auto px-4 pb-12">
    <div class="grid md:grid-cols-3 gap-4">
      <div class="card p-6 text-center">
        <div class="w-12 h-12 mx-auto mb-3 flex items-center justify-center rounded-full bg-surface">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-navy-700)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 9V5a3 3 0 00-3-3l-4 9v11h11.28a2 2 0 002-1.7l1.38-9a2 2 0 00-2-2.3H14z"/></svg>
        </div>
        <h3 class="font-sans font-semibold text-ink text-sm">Ďakujeme za návštevu</h3>
        <p class="text-xs text-muted mt-1">Každý návrh na zlepšenie nás poteší.</p>
        <p class="font-semibold text-navy-700 text-sm mt-2">ajuva@ajuva.sk</p>
      </div>
      <div class="card p-5 flex flex-col justify-center items-center">
        <div class="font-display text-3xl font-semibold text-navy-900">2006</div>
        <p class="text-xs text-muted mt-1">Na trhu od roku</p>
      </div>
      <div class="card p-5 flex flex-col justify-center items-center">
        <div class="font-display text-3xl font-semibold text-navy-900">10+</div>
        <p class="text-xs text-muted mt-1">Oblastí služieb</p>
      </div>
    </div>
  </section>

  <!-- Updated -->
  <div class="text-center text-xs text-muted pb-8">
    Aktualizované: 29.12.2025
  </div>

  <!-- ═══════ NAME-DAY SCRIPT ═══════ -->
  <script>
    const nameDays: Record<string, string> = {
      '1.1.': 'Courtney','2.1.': 'Alexandra','3.1.': 'Daniela','4.1.': 'Drahoslav','5.1.': 'Andrea',
      '6.1.': 'Antónia','7.1.': 'Bohuslava','8.1.': 'Severín','9.1.': 'Alex','10.1.': 'Dáša',
      '11.1.': 'Malvína','12.1.': 'Ernest','13.1.': 'Rastislav','14.1.': 'Radovan','15.1.': 'Dobroslav',
      '16.1.': 'Kristína','17.1.': 'Nataša','18.1.': 'Bohdana','19.1.': 'Mário','20.1.': 'Dalibor',
      '21.1.': 'Vincent','22.1.': 'Zora','23.1.': 'Miloš','24.1.': 'Timotej','25.1.': 'Gejza',
      '26.1.': 'Tamara','27.1.': 'Bohuš','28.1.': 'Alfonz','29.1.': 'Gašpar','30.1.': 'Ema','31.1.': 'Emil',
      '1.2.': 'Tatiana','2.2.': 'Erik','3.2.': 'Blažej','4.2.': 'Veronika','5.2.': 'Agáta',
      '6.2.': 'Dorota','7.2.': 'Vanda','8.2.': 'Zoja','9.2.': 'Zdenko','10.2.': 'Gabriela',
      '11.2.': 'Dezider','12.2.': 'Perla','13.2.': 'Arpád','14.2.': 'Valentín','15.2.': 'Pravoslav',
      '16.2.': 'Ida','17.2.': 'Miloslava','18.2.': 'Jaromír','19.2.': 'Vlasta','20.2.': 'Lívia',
      '21.2.': 'Eleonóra','22.2.': 'Etela','23.2.': 'Roman','24.2.': 'Matej','25.2.': 'Frederik',
      '26.2.': 'Viktor','27.2.': 'Alexander','28.2.': 'Zlatica','29.2.': 'Radomír',
      '1.3.': 'Albín','2.3.': 'Anežka','3.3.': 'Bohumil','4.3.': 'Kazimír','5.3.': 'Fridrich',
      '6.3.': 'Radoslav','7.3.': 'Tomáš','8.3.': 'Alan','9.3.': 'Františka','10.3.': 'Branislav',
      '11.3.': 'Angelina','12.3.': 'Gregor','13.3.': 'Vlastimil','14.3.': 'Matilda','15.3.': 'Svetlana',
      '15.6.': 'Vít','16.6.': 'Bianka',
    };
    const quotes = [
      '„Bezpečnosť nie je produkt, ale proces."',
      '„Dobrý kurič je ten, koho nevidno, ale cítiť teplo."',
      '„Kto je pripravený, nie je prekvapený."',
      '„Najlepší hasič je ten, ktorý nemusel hasiť."',
      '„Vedomosti sú teplo, ktoré nikdy nevyhasne."',
      '„Práca bez BOZP je ako oheň bez komína."',
    ];
    const el = document.getElementById('name-day');
    const quoteEl = document.getElementById('daily-quote');
    if (el && quoteEl) {
      const now = new Date();
      const key = `${now.getDate()}.${now.getMonth() + 1}.`;
      el.textContent = nameDays[key] || '—';
      const doy = Math.floor((now.getTime() - new Date(now.getFullYear(), 0, 0).getTime()) / 86400000);
      quoteEl.textContent = quotes[doy % quotes.length];
    }
  </script>
</MainLayout>
