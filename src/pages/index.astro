---
import MainLayout from '../layouts/MainLayout.astro';
import Gallery from '../components/Gallery.astro';
import ServiceList from '../components/ServiceList.astro';
import ContactCard from '../components/ContactCard.astro';
import Jokes from '../components/Jokes.astro';
---

<MainLayout>
  <!-- Row 1: Banner + Title + Info icon -->
  <div class="flex flex-col md:flex-row items-center justify-center gap-4 mb-6">
    <!-- Info icon -->
    <div class="flex-shrink-0">
      <img src="/images/info.png" alt="Info" class="w-20 h-20" loading="eager" />
    </div>
    <!-- Title -->
    <div class="flex-1 text-center">
      <h1 class="text-2xl md:text-3xl font-bold text-navy leading-snug" style="font-family: Georgia, 'Times New Roman', serif;">
        AKTUÁLNE TERMÍNY ŠKOLENÍ A ODBORNEJ PRÍPRAVY.
      </h1>
      <p class="text-red-600 font-bold text-sm md:text-base mt-1">
        Pozor — zmena zákona č.124,125/2006 a 314/2012
      </p>
    </div>
  </div>

  <!-- Row 2: Gallery + Aktuálne informácie -->
  <div class="flex flex-col md:flex-row gap-6 mb-6">
    <!-- Gallery -->
    <div class="flex-shrink-0">
      <Gallery />
    </div>

    <!-- Aktuálne informácie box -->
    <div class="flex-1 card-retro overflow-hidden">
      <div class="tab-retro text-center text-sm py-1">
        AKTUÁLNE INFORMÁCIE
      </div>
      <div class="scroll-box bg-info-retro" style="height: 235px;">
        <div class="scroll-box-inner p-4 text-sm text-gray-800 space-y-4">
          <div class="bg-white/60 rounded p-3 border border-navy/10">
            <p>V časti <a href="/skolenia/kuric-1-5-triedy" class="font-bold text-navy hover:underline">ŠKOLENIA</a> nájdete ďalšie aktuálne termíny pre odbornú a aktualizačnú odbornú prípravu obslúh vyhradených technických zariadení tlakových a plynových.</p>
            <p class="mt-1">Aktuálny termín: <a href="/skolenia/kuric-1-5-triedy" class="font-bold text-red-600 hover:underline">21.01 a 22.01.2026</a></p>
          </div>

          <div class="bg-white/60 rounded p-3 border border-navy/10">
            <p>V časti <a href="/skolenia/kuric-1-5-triedy" class="font-bold text-navy hover:underline">ŠKOLENIA</a> nájdete termíny pre aktualizačnú odbornú prípravu revíznych technikov a osoby na opravy VTZ tlakové a plynové.</p>
          </div>

          <div class="bg-red-50 rounded p-3 border border-red-200">
            <p class="font-bold text-red-700">Pozor!</p>
            <p>Od 01.01.2023 sú platné nové ustanovenia zákona č.124/2006 Z.z. Zmeny sú aj v §16.</p>
            <p class="mt-1">Je novelizovaná vyhláška č.356/2007 Z.z. o obsahu a rozsahu vzdelávania vyhl. č.66/2023.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Row 3: Service List + Contact Card -->
  <div class="flex flex-col md:flex-row gap-6 mb-6">
    <div class="flex-1">
      <ServiceList />
    </div>
    <div class="w-full md:w-80 flex-shrink-0">
      <ContactCard />
    </div>
  </div>

  <!-- Row 4: 2026 Fun Widget + Thanks box + Quick facts -->
  <div class="flex flex-col md:flex-row gap-6 mb-6">
    <!-- 2026 Interactive widget: Daily wisdom + name day -->
    <div class="card-retro p-5 flex-1 flex flex-col items-center justify-center min-h-[350px] bg-gradient-to-b from-[#0a0a2e] to-navy text-white relative overflow-hidden">
      <div class="absolute inset-0 bg-[url('/images/bg.jpg')] opacity-5"></div>
      <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-cyan-400 via-accent to-cyan-400"></div>
      <div class="relative z-10 text-center">
        <div class="text-6xl mb-4 animate-bounce">🔮</div>
        <h3 class="text-xl font-bold text-accent mb-3" style="font-family: Georgia, 'Times New Roman', serif;">
          Dnes má meniny
        </h3>
        <div id="name-day" class="text-3xl font-bold text-white mb-1" style="font-family: Georgia, 'Times New Roman', serif;">
          —
        </div>
        <p class="text-cyan-200/70 text-sm mb-4">Slovenský kalendár</p>
        <hr class="border-cyan-400/20 w-32 mx-auto mb-4" />
        <div class="text-xs text-cyan-200/80 italic max-w-xs mx-auto leading-relaxed" id="daily-quote">
          "Najlepší čas na začiatok bol včera. Druhý najlepší je dnes."
        </div>
        <div class="mt-4 flex justify-center gap-3">
          <span class="text-2xl cursor-pointer hover:scale-125 transition-transform" title="Počasie">🌤️</span>
          <span class="text-2xl cursor-pointer hover:scale-125 transition-transform" title="Energia">⚡</span>
          <span class="text-2xl cursor-pointer hover:scale-125 transition-transform" title="Bezpečnosť">🛡️</span>
        </div>
      </div>
    </div>

    <!-- Thanks for visiting -->
    <div class="card-retro thanks-box p-5 flex-1 text-center flex flex-col items-center justify-center">
      <h3 class="text-lg font-bold text-navy mb-3" style="font-family: Georgia, 'Times New Roman', serif;">
        Ďakujeme za návštevu našej stránky.
      </h3>
      <p class="text-sm text-gray-700 mb-3">Každý návrh na zlepšenie nás poteší.</p>
      <img
        src="/images/035.gif"
        alt="Ďakujeme"
        class="w-28 h-auto mb-3"
        loading="lazy"
      />
      <p class="font-bold text-navy">ajuva@ajuva.sk</p>
    </div>

    <!-- Quick stats card -->
    <div class="card-retro p-5 flex-1 flex items-center justify-center min-h-[350px] bg-gradient-to-b from-white to-cream/30">
      <div class="text-center space-y-4">
        <p class="text-xs text-navy font-bold tracking-widest uppercase">AJUVA Š+S s.r.o.</p>
        <div class="space-y-3">
          <div class="bg-navy/5 rounded-xl p-3">
            <div class="text-2xl font-bold text-navy">2006</div>
            <p class="text-xs text-gray-500">Na trhu od roku</p>
          </div>
          <div class="bg-navy/5 rounded-xl p-3">
            <div class="text-2xl font-bold text-navy">10+</div>
            <p class="text-xs text-gray-500">Oblastí služieb</p>
          </div>
          <div class="bg-navy/5 rounded-xl p-3">
            <div class="text-2xl font-bold text-navy">SK</div>
            <p class="text-xs text-gray-500">Celé Slovensko</p>
          </div>
        </div>
        <p class="text-xs text-gray-400 mt-3">Zvolenská cesta 20, Banská Bystrica</p>
      </div>
    </div>
  </div>

  <!-- Row 5: Jokes + Interactive Google Map -->
  <div class="flex flex-col md:flex-row gap-6 mb-6">
    <div class="flex-1">
      <Jokes />
    </div>
    <div class="w-full md:w-96 flex-shrink-0">
      <div class="card-retro overflow-hidden rounded-xl">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2633.304570123456!2d19.1345!3d48.7395!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x471516c5a1b0e5f7%3A0x4a2b1c3d4e5f6789!2sZvolensk%C3%A1%20cesta%2020%2C%20974%2001%20Bansk%C3%A1%20Bystrica!5e0!3m2!1ssk!2ssk!4v1699999999999"
          width="100%"
          height="400"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Mapa — AJUVA Banská Bystrica"
          class="w-full"
        >
        </iframe>
        <div class="bg-navy p-3 flex items-center justify-between">
          <div>
            <p class="text-white text-sm font-bold">Zvolenská cesta 20, Banská Bystrica</p>
            <p class="text-cyan-300/70 text-xs">Parkovanie pri budove</p>
          </div>
          <a
            href="https://maps.google.com/?q=Zvolenská+cesta+20+Banská+Bystrica"
            target="_blank"
            rel="noopener"
            class="text-accent text-xs font-bold hover:underline whitespace-nowrap"
          >
            📍 Navigovať →
          </a>
        </div>
      </div>
    </div>
  </div>

