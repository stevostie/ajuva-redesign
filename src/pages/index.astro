---
import MainLayout from '../layouts/MainLayout.astro';
import Gallery from '../components/Gallery.astro';
import ServiceList from '../components/ServiceList.astro';
import ContactCard from '../components/ContactCard.astro';
import Jokes from '../components/Jokes.astro';
---

<MainLayout>
  <!-- ═══ HERO — bold, layered, experimental ═══ -->
  <section class="relative bg-brand overflow-hidden min-h-[88vh] flex items-center">
    <div class="absolute inset-0 opacity-[0.04]" style="background:radial-gradient(circle at 20% 80%, white 1px, transparent 1px);background-size:60px 60px;"></div>
    <div class="absolute top-[-20%] right-[-10%] w-[600px] h-[600px] rounded-full bg-accent/10 blur-3xl"></div>
    <div class="absolute bottom-[-10%] left-[-5%] w-[400px] h-[400px] rounded-full bg-brand-500/20 blur-3xl"></div>

    <div class="relative w-full max-w-7xl mx-auto px-4 py-20 md:py-0">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <!-- LEFT: big text + stats -->
        <div class="space-y-8">
          <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm rounded-full px-4 py-1.5 border border-white/10">
            <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
            <span class="text-white/80 text-xs font-medium">Prihlasovanie otvorené</span>
          </div>

          <h1 class="text-5xl md:text-6xl lg:text-7xl font-black text-white leading-[0.95] tracking-tight">
            Školenia<br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent via-red-400 to-accent">pre profesionálov</span>
          </h1>

          <p class="text-white/45 text-lg max-w-md leading-relaxed">
            20 rokov skúseností. 3 000+ absolventov. Jeden cieľ — vaša bezpečnosť a odbornosť.
          </p>

          <div class="flex flex-wrap gap-3">
            <a href="/skolenia/kuric-1-5-triedy" class="btn btn-primary !py-3.5 !px-7 !text-base !rounded-xl">
              Aktuálne termíny <span class="text-lg">→</span>
            </a>
            <a href="/kontakt/ajuva" class="btn btn-outline-light !py-3.5 !px-7 !text-base !rounded-xl">
              Kontakt
            </a>
          </div>

          <!-- Big stat numbers -->
          <div class="flex gap-12 pt-8 border-t border-white/[0.08]">
            <div>
              <div class="text-5xl font-black text-white">20+</div>
              <div class="text-white/35 text-sm mt-1">rokov</div>
            </div>
            <div>
              <div class="text-5xl font-black text-white">3k+</div>
              <div class="text-white/35 text-sm mt-1">absolventov</div>
            </div>
            <div>
              <div class="text-5xl font-black text-white">10</div>
              <div class="text-white/35 text-sm mt-1">služieb</div>
            </div>
          </div>
        </div>

        <!-- RIGHT: glass card -->
        <div class="relative hidden md:block">
          <div class="absolute -top-10 -right-10 w-40 h-40 rounded-full bg-accent/20 blur-2xl"></div>
          <div class="relative bg-white/[0.06] backdrop-blur-xl border border-white/[0.08] rounded-3xl p-8 space-y-6">
            <!-- Date card -->
            <div>
              <div class="flex items-center justify-between mb-4">
                <span class="badge badge-red text-xs px-3 py-1">Najbližšie</span>
                <span class="text-white/25 text-xs">2026</span>
              </div>
              <div class="text-6xl font-black text-white tracking-tighter mb-2">21.–22.</div>
              <div class="text-white/30 text-lg">január</div>
            </div>
            <hr class="border-white/[0.06]" />
            <div>
              <p class="text-white/80 font-bold mb-3">Kurič I. – V. triedy</p>
              <div class="space-y-2 text-white/40 text-sm">
                <div class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-accent"></span> Odborná príprava</div>
                <div class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-accent"></span> Certifikát o absolvovaní</div>
                <div class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-accent"></span> Platnosť po celom SK</div>
              </div>
            </div>
            <a href="/skolenia/kuric-1-5-triedy" class="flex items-center justify-between bg-white/10 hover:bg-white/15 rounded-2xl px-5 py-4 text-white font-semibold transition-colors">
              Detail a prihláška <span class="text-lg">→</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TERMÍNY — overlapping cards ═══ -->
  <section class="relative -mt-20 pb-0 z-10">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-5">
        <div class="card p-7 bg-white shadow-xl hover:shadow-2xl transition-shadow duration-300" style="box-shadow:0 25px 50px -12px rgba(0,0,0,0.12);">
          <div class="flex items-start gap-4">
            <div class="w-14 h-14 rounded-2xl bg-accent/10 flex items-center justify-center flex-shrink-0">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <span class="badge badge-red text-[11px]">Školenie</span>
              <h3 class="text-xl font-extrabold text-ink mt-2 leading-tight">Kurič I. – V. triedy</h3>
              <p class="text-ink-500 text-sm mt-2.5 leading-relaxed">Kompletná odborná príprava obslúh VTZ — teória aj prax. Certifikovaný kurz s celoslovenskou platnosťou.</p>
              <div class="flex items-center justify-between mt-5 pt-4 border-t border-line">
                <div class="flex items-center gap-3">
                  <div class="text-2xl font-black text-brand tracking-tight">21.–22.01.</div>
                  <span class="text-ink-300 text-xs">2026</span>
                </div>
                <a href="/skolenia/kuric-1-5-triedy" class="btn btn-primary !text-sm !py-2.5 !px-5 !rounded-xl">Detail</a>
              </div>
            </div>
          </div>
        </div>

        <div class="card p-7 bg-white shadow-xl hover:shadow-2xl transition-shadow duration-300" style="box-shadow:0 25px 50px -12px rgba(0,0,0,0.12);">
          <div class="flex items-start gap-4">
            <div class="w-14 h-14 rounded-2xl bg-brand/10 flex items-center justify-center flex-shrink-0">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <span class="badge badge-brand text-[11px]">Školenie</span>
              <h3 class="text-xl font-extrabold text-ink mt-2 leading-tight">Revízni technici VTZ</h3>
              <p class="text-ink-500 text-sm mt-2.5 leading-relaxed">Aktualizačná odborná príprava revíznych technikov a opráv VTZ tlakových a plynových — priebežne.</p>
              <div class="flex items-center justify-between mt-5 pt-4 border-t border-line">
                <div class="flex items-center gap-3">
                  <div class="text-2xl font-black text-brand tracking-tight">Priebežne</div>
                </div>
                <a href="/skolenia/kuric-1-5-triedy" class="btn btn-outline-brand !text-sm !py-2.5 !px-5 !rounded-xl">Termíny</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ SLUŽBY — experimental grid ═══ -->
  <section class="section mt-16">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-14 gap-4">
        <div>
          <p class="text-accent text-xs font-bold uppercase tracking-[0.15em] mb-3">Čo ponúkame</p>
          <h2 class="text-4xl md:text-5xl font-black text-ink tracking-tight leading-[1.05]">
            Komplexné<br/>služby
          </h2>
        </div>
        <p class="text-ink-500 max-w-sm text-sm">Od odborných prehliadok cez certifikované školenia až po spracovanie kompletnej dokumentácie BOZP a PO.</p>
      </div>
      <ServiceList />
    </div>
  </section>

  <!-- ═══ GALÉRIA + INFO + MENINY ═══ -->
  <section class="section bg-surface">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid md:grid-cols-12 gap-8">
        <!-- Gallery spans 7 -->
        <div class="md:col-span-7">
          <p class="text-accent text-xs font-bold uppercase tracking-[0.15em] mb-3">Galéria</p>
          <h2 class="text-4xl md:text-5xl font-black text-ink tracking-tight leading-[1.05] mb-8">Z našich školení</h2>
          <Gallery />
        </div>
        <!-- Sidebar spans 5 -->
        <div class="md:col-span-5 space-y-6">
          <!-- Info -->
          <div class="card-static bg-white p-6">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-8 h-8 rounded-lg bg-accent/10 flex items-center justify-center">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
              </div>
              <span class="text-xs font-bold uppercase tracking-wider text-ink-500">Aktuálne info</span>
            </div>
            <div class="text-sm text-ink-700 space-y-3 leading-relaxed">
              <p>V časti <a href="/skolenia/kuric-1-5-triedy" class="font-bold text-brand hover:underline">Školenia</a> nájdete termíny odbornej prípravy obslúh VTZ.</p>
              <p class="font-extrabold text-accent">Termín: 21.–22.01.2026</p>
              <hr class="border-line" />
              <p>Termíny pre revíznych technikov a opravy VTZ v časti <a href="/skolenia/kuric-1-5-triedy" class="font-bold text-brand hover:underline">Školenia</a>.</p>
              <div class="bg-accent-50 border border-accent/15 rounded-xl p-4 mt-3">
                <p class="font-extrabold text-accent text-xs uppercase tracking-wider mb-1">Legislatíva</p>
                <p class="text-xs text-ink-700 leading-relaxed">Od 01.01.2023 novela zákona č.124/2006 Z.z. a vyhlášky č.356/2007 Z.z.</p>
              </div>
            </div>
          </div>

          <!-- Meniny -->
          <div class="relative overflow-hidden rounded-2xl bg-brand p-6 text-white text-center" style="background:linear-gradient(145deg, #0A1E6E 0%, #1E3FA8 60%, #2A46B8 100%);">
            <div class="absolute -top-10 -right-10 w-32 h-32 rounded-full bg-white/[0.04]"></div>
            <div class="relative">
              <p class="text-white/40 text-[11px] font-bold uppercase tracking-[0.2em] mb-3">Meniny</p>
              <div id="name-day" class="text-4xl font-black tracking-tight">—</div>
              <div class="w-8 h-0.5 bg-white/20 mx-auto my-4"></div>
              <div id="daily-quote" class="text-white/40 text-xs italic leading-relaxed max-w-[220px] mx-auto"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ KONTAKT + MAPA ═══ -->
  <section class="section">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-8">
        <ContactCard />
        <div class="card-static overflow-hidden flex flex-col min-h-[500px]">
          <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2633.304570123456!2d19.1345!3d48.7395!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x471516c5a1b0e5f7%3A0x4a2b1c3d4e5f6789!2sZvolensk%C3%A1%20cesta%2020%2C%20974%2001%20Bansk%C3%A1%20Bystrica!5e0!3m2!1ssk!2ssk!4v1699999999999" width="100%" style="border:0;min-height:350px;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Mapa AJUVA" class="flex-1"></iframe>
          <div class="px-6 py-4 flex items-center justify-between bg-surface border-t border-line">
            <p class="font-extrabold text-ink text-sm">Zvolenská cesta 20, B. Bystrica</p>
            <a href="https://maps.google.com/?q=Zvolenská+cesta+20+Banská+Bystrica" target="_blank" rel="noopener" class="text-accent font-bold text-sm hover:underline">Navigovať →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ ZÁBAVA ═══ -->
  <section class="section bg-surface">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid md:grid-cols-3 gap-8">
        <div class="md:col-span-2">
          <p class="text-accent text-xs font-bold uppercase tracking-[0.15em] mb-3">Zábava</p>
          <h2 class="text-4xl md:text-5xl font-black text-ink tracking-tight leading-[1.05] mb-8">
            <a href="/zabava/vtipy" class="hover:text-accent transition-colors">Vtipy</a>
          </h2>
          <div class="card-static p-6 bg-white"><Jokes /></div>
        </div>
        <div class="card-static p-8 text-center bg-white flex flex-col items-center justify-center gap-4">
          <div class="w-16 h-16 rounded-2xl bg-brand/5 flex items-center justify-center">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 9V5a3 3 0 00-3-3l-4 9v11h11.28a2 2 0 002-1.7l1.38-9a2 2 0 00-2-2.3H14zM7 22H4a2 2 0 01-2-2v-7a2 2 0 012-2h3"/></svg>
          </div>
          <h3 class="font-extrabold text-xl text-ink">Ďakujeme</h3>
          <p class="text-ink-500 text-sm">za dôveru a návštevu.</p>
          <a href="mailto:ajuva@ajuva.sk" class="text-brand font-bold text-sm hover:underline">ajuva@ajuva.sk</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CTA BANNER ═══ -->
  <section class="relative bg-brand overflow-hidden py-20 md:py-28">
    <div class="absolute top-[-30%] left-[10%] w-96 h-96 rounded-full bg-accent/10 blur-3xl"></div>
    <div class="relative max-w-2xl mx-auto text-center px-4">
      <h2 class="text-4xl md:text-5xl font-black text-white tracking-tight leading-[1.05]">Máte záujem o spoluprácu?</h2>
      <p class="text-white/40 text-lg mt-5">Nezáväzná konzultácia, individuálna cenová ponuka, flexibilné termíny.</p>
      <div class="mt-8">
        <a href="/kontakt/ajuva" class="btn !bg-white !text-brand !py-4 !px-8 !text-base !rounded-xl font-extrabold hover:!bg-white/90 transition-all hover:scale-105">
          Kontaktujte nás <span class="text-xl">→</span>
        </a>
      </div>
    </div>
  </section>

  <div class="bg-surface text-center py-3 text-xs text-ink-300 font-medium tracking-wide">Aktualizované: 29. 12. 2025</div>

  <script>
