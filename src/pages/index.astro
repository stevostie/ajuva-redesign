---
import MainLayout from '../layouts/MainLayout.astro';
import Gallery from '../components/Gallery.astro';
import ServiceList from '../components/ServiceList.astro';
import ContactCard from '../components/ContactCard.astro';
import Jokes from '../components/Jokes.astro';
---

<MainLayout>
  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="relative bg-brand overflow-hidden">
    <!-- Subtle pattern -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image:radial-gradient(circle at 25% 25%, white 1px, transparent 1px);background-size:40px 40px;"></div>
    <div class="absolute top-0 right-0 w-1/2 h-full opacity-[0.04]" style="background:radial-gradient(ellipse at 70% 30%, white 0%, transparent 70%);"></div>

    <div class="relative max-w-7xl mx-auto px-4 pt-20 pb-20 md:pt-28 md:pb-28">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <!-- Left -->
        <div class="animate-fade-up animate-fade-up-1">
          <p class="inline-flex items-center gap-2 bg-accent/15 text-accent text-xs font-bold px-3 py-1.5 rounded-full mb-6 tracking-wide uppercase">
            <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
            Prihlasovanie otvorené
          </p>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-[1.08] tracking-tight">
            Odborné školenia<br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-white via-white to-white/70">pre priemysel</span>
          </h1>
          <p class="text-white/60 text-lg mt-5 max-w-lg leading-relaxed">
            Viac ako <strong class="text-white font-semibold">20 rokov</strong> pripravujeme odborníkov v oblasti BOZP, revízií VTZ a obsluhy technických zariadení.
          </p>
          <div class="flex flex-wrap gap-3 mt-8">
            <a href="/skolenia/kuric-1-5-triedy" class="btn btn-primary">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              Aktuálne termíny
            </a>
            <a href="/kontakt/ajuva" class="btn btn-outline-light">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
              Kontaktujte nás
            </a>
          </div>
          <!-- Stats -->
          <div class="flex flex-wrap gap-x-10 gap-y-4 mt-12 pt-10 border-t border-white/[0.08]">
            <div><div class="stat-number">20+</div><div class="stat-label">rokov skúseností</div></div>
            <div><div class="stat-number">3 000+</div><div class="stat-label">vyškolených osôb</div></div>
            <div><div class="stat-number">10+</div><div class="stat-label">oblastí služieb</div></div>
          </div>
        </div>
        <!-- Right: feature card -->
        <div class="animate-fade-up animate-fade-up-2 hidden md:block">
          <div class="bg-white/5 backdrop-blur-sm border border-white/[0.08] rounded-2xl p-8">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 rounded-xl bg-accent/20 flex items-center justify-center text-accent">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 1.1 2.7 2 6 2s6-.9 6-2v-5"/></svg>
              </div>
              <div>
                <p class="text-white font-bold text-sm">Najbližší termín</p>
                <p class="text-white/50 text-xs">Kurič I. – V. triedy</p>
              </div>
            </div>
            <p class="text-white/90 font-extrabold text-4xl tracking-tight mb-1">21.–22.01.</p>
            <p class="text-white/40 text-sm mb-6">Január 2026</p>
            <a href="/skolenia/kuric-1-5-triedy" class="inline-flex items-center gap-1.5 text-accent font-semibold text-sm hover:gap-2.5 transition-all">
              Detail a prihláška <span>→</span>
            </a>
            <hr class="border-white/[0.06] my-6" />
            <div class="text-white/40 text-xs space-y-2">
              <p class="flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-success"></span> Odborná príprava</p>
              <p class="flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-success"></span> Certifikát o absolvovaní</p>
              <p class="flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-success"></span> Platnosť po celom SK</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ TERMÍNY ═══════════════ -->
  <section class="section bg-surface">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <p class="section-label">Termíny</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-ink tracking-tight">Najbližšie školenia</h2>
        <p class="text-ink-500 mt-3 max-w-xl mx-auto">Vyberte si z aktuálne vypísaných termínov alebo nás kontaktujte pre individuálny kurz.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        <div class="card p-6 md:p-8 flex flex-col">
          <div class="flex items-start justify-between mb-4">
            <span class="badge badge-red">Školenie</span>
            <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center text-accent">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </div>
          </div>
          <h3 class="text-xl font-bold text-ink leading-snug">Kurič I. – V. triedy</h3>
          <p class="text-ink-500 text-sm mt-2 leading-relaxed flex-1">Kompletná odborná a aktualizačná príprava obslúh vyhradených technických zariadení tlakových a plynových.</p>
          <div class="flex items-center gap-3 mt-5 pt-5 border-t border-line">
            <div class="w-10 h-10 rounded-lg bg-brand/5 flex items-center justify-center text-brand flex-shrink-0">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </div>
            <div>
              <p class="font-extrabold text-brand text-lg leading-none">21.–22.01.2026</p>
              <p class="text-ink-300 text-xs mt-0.5">2-dňový kurz</p>
            </div>
          </div>
          <a href="/skolenia/kuric-1-5-triedy" class="link-arrow mt-4">Viac informácií <span>→</span></a>
        </div>

        <div class="card p-6 md:p-8 flex flex-col">
          <div class="flex items-start justify-between mb-4">
            <span class="badge badge-brand">Školenie</span>
            <div class="w-10 h-10 rounded-xl bg-brand/10 flex items-center justify-center text-brand">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
          </div>
          <h3 class="text-xl font-bold text-ink leading-snug">Revízni technici a opravy VTZ</h3>
          <p class="text-ink-500 text-sm mt-2 leading-relaxed flex-1">Aktualizačná odborná príprava pre revíznych technikov a osoby vykonávajúce opravy VTZ tlakových a plynových zariadení.</p>
          <div class="flex items-center gap-3 mt-5 pt-5 border-t border-line">
            <div class="w-10 h-10 rounded-lg bg-brand/5 flex items-center justify-center text-brand flex-shrink-0">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </div>
            <div>
              <p class="font-extrabold text-brand text-lg leading-none">Priebežne</p>
              <p class="text-ink-300 text-xs mt-0.5">Podľa záujmu</p>
            </div>
          </div>
          <a href="/skolenia/kuric-1-5-triedy" class="link-arrow mt-4">Zobraziť termíny <span>→</span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ SLUŽBY ═══════════════ -->
  <section class="section">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-14">
        <p class="section-label">Služby</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-ink tracking-tight">Čo ponúkame</h2>
        <p class="text-ink-500 mt-3 max-w-xl mx-auto">Komplexné služby v oblasti bezpečnosti práce, revízií a odbornej prípravy pre firmy aj jednotlivcov.</p>
      </div>
      <ServiceList />
    </div>
  </section>

  <!-- ═══════════════ GALÉRIA ═══════════════ -->
  <section class="section bg-surface">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid md:grid-cols-5 gap-10">
        <div class="md:col-span-3">
          <p class="section-label">Galéria</p>
          <h2 class="text-3xl md:text-4xl font-extrabold text-ink tracking-tight mb-8">Z našich školení</h2>
          <Gallery />
        </div>
        <div class="md:col-span-2 space-y-6">
          <div class="card-static p-6">
            <h3 class="font-bold text-ink mb-4 flex items-center gap-2 text-sm uppercase tracking-wide text-ink-500">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
              Aktuálne informácie
            </h3>
            <div class="text-sm text-ink-700 leading-relaxed space-y-3 max-h-[320px] overflow-y-auto pr-1">
              <p>V časti <a href="/skolenia/kuric-1-5-triedy" class="font-semibold text-brand hover:underline">Školenia</a> nájdete aktuálne termíny pre odbornú a aktualizačnú prípravu obslúh VTZ tlakových a plynových.</p>
              <p class="font-semibold text-accent">Aktuálny termín — 21.01 a 22.01.2026</p>
              <hr class="border-line" />
              <p>V časti <a href="/skolenia/kuric-1-5-triedy" class="font-semibold text-brand hover:underline">Školenia</a> nájdete termíny pre aktualizačnú odbornú prípravu revíznych technikov a osôb na opravy VTZ.</p>
              <div class="bg-accent-50 border border-accent/20 rounded-lg p-3 mt-3">
                <p class="font-bold text-accent text-xs uppercase tracking-wide mb-1">Pozor — legislatívna zmena</p>
                <p class="text-xs text-ink-700">Od 01.01.2023 platia nové ustanovenia zákona č.124/2006 Z.z. Novelizovaná vyhláška č.356/2007 Z.z. (vyhl. č.66/2023).</p>
              </div>
            </div>
          </div>
          <!-- Name day -->
          <div class="card-static bg-brand text-white p-6 text-center relative overflow-hidden" style="background:linear-gradient(135deg, #0A1E6E 0%, #16308F 100%);">
            <div class="absolute top-0 right-0 w-32 h-32 rounded-full bg-white/[0.03] -translate-y-1/2 translate-x-1/2"></div>
            <div class="relative">
              <p class="text-white/40 text-xs font-semibold uppercase tracking-widest mb-2">Meniny</p>
              <div id="name-day" class="text-3xl font-extrabold">—</div>
              <p class="text-white/30 text-xs mt-1">Slovenský kalendár</p>
              <div class="w-12 h-px bg-white/15 mx-auto my-4"></div>
              <div id="daily-quote" class="text-white/50 text-xs italic leading-relaxed max-w-[240px] mx-auto"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ KONTAKT + MAPA ═══════════════ -->
  <section class="section">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-8">
        <ContactCard />
        <div class="card-static overflow-hidden flex flex-col">
          <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2633.304570123456!2d19.1345!3d48.7395!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x471516c5a1b0e5f7%3A0x4a2b1c3d4e5f6789!2sZvolensk%C3%A1%20cesta%2020%2C%20974%2001%20Bansk%C3%A1%20Bystrica!5e0!3m2!1ssk!2ssk!4v1699999999999" width="100%" height="100%" style="border:0;min-height:400px;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Mapa — AJUVA, Zvolenská cesta 20, Banská Bystrica" class="flex-1"></iframe>
          <div class="px-6 py-4 flex items-center justify-between bg-surface border-t border-line">
            <div>
              <p class="font-bold text-ink text-sm">Zvolenská cesta 20, Banská Bystrica</p>
              <p class="text-ink-300 text-xs">Bezplatné parkovanie pri budove</p>
            </div>
            <a href="https://maps.google.com/?q=Zvolenská+cesta+20+Banská+Bystrica" target="_blank" rel="noopener" class="btn btn-outline-brand !text-sm !py-2 !px-4">
              Navigovať
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ ZÁBAVA ═══════════════ -->
  <section class="section bg-surface">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid md:grid-cols-3 gap-8">
        <div class="md:col-span-2">
          <p class="section-label">Zábava</p>
          <h2 class="text-3xl md:text-4xl font-extrabold text-ink tracking-tight mb-8">
            <a href="/zabava/vtipy" class="hover:text-brand transition-colors">Vtipy na tento týždeň</a>
          </h2>
          <div class="card-static p-6">
            <Jokes />
          </div>
        </div>
        <div class="card-static p-8 text-center flex flex-col justify-center items-center bg-white">
          <div class="w-16 h-16 rounded-2xl bg-brand/5 flex items-center justify-center mb-5">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 9V5a3 3 0 00-3-3l-4 9v11h11.28a2 2 0 002-1.7l1.38-9a2 2 0 00-2-2.3H14zM7 22H4a2 2 0 01-2-2v-7a2 2 0 012-2h3"/></svg>
          </div>
          <h3 class="font-bold text-lg text-ink mb-1">Ďakujeme za dôveru</h3>
          <p class="text-ink-500 text-sm mb-4">Každý návrh na zlepšenie nás poteší.</p>
          <a href="mailto:ajuva@ajuva.sk" class="text-brand font-semibold text-sm hover:underline">ajuva@ajuva.sk</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ CTA BANNER ═══════════════ -->
  <section class="relative bg-brand overflow-hidden">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image:radial-gradient(circle at 75% 50%, white 1px, transparent 1px);background-size:30px 30px;"></div>
    <div class="relative max-w-3xl mx-auto text-center px-4 py-20 md:py-24">
      <h2 class="text-3xl md:text-4xl font-extrabold text-white tracking-tight">Máte záujem o spoluprácu?</h2>
      <p class="text-white/50 text-lg mt-4">Kontaktujte nás pre nezáväznú konzultáciu alebo individuálnu cenovú ponuku.</p>
      <div class="flex flex-wrap justify-center gap-3 mt-8">
        <a href="/kontakt/ajuva" class="btn btn-primary !bg-white !text-brand hover:!bg-white/90 hover:!text-brand shadow-none">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          Kontaktujte nás
        </a>
      </div>
    </div>
  </section>

  <div class="bg-surface text-center py-3 text-xs text-ink-300">Aktualizované: 29. 12. 2025</div>

