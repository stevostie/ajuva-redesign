---
import Header from '../components/Header.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title?: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="sk-SK">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Úvodná stránka AJUVA Š+S s.r.o. Banská Bystrica — školenia kuričov, obsluha technických zariadení, BOZP, PO, revízie TZ a PZ" />
    <meta name="keywords" content="školenie kuričov, kurič, obsluha technických zariadení, obsluha plynových zariadení, obsluha tlakových zariadení, kurz kuričov, BOZP, PO, bezpečnosť a ochrana zdravia pri práci, požiarna ochrana, revízie TZ a PZ" />
    <meta name="author" content="AJUVA Š+S s.r.o. Banská Bystrica" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <title>{title ? `${title} — AJUVA B.Bystrica` : 'DOMOV — AJUVA B.Bystrica'}</title>
  </head>
  <body class="min-h-screen">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:bg-navy focus:text-white focus:p-2 focus:z-50 focus:rounded">
      Preskočiť na obsah
    </a>

    <div id="app-content" class="min-h-screen flex flex-col">
      <div class="sticky top-0 z-50">
        <Header />
        <Navigation />
      </div>

      <main id="main-content" class="flex-1">
        <slot />
      </main>

      <Footer />
    </div>
  </body>
</html>
