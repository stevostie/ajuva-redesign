---

<header class="bg-brand sticky top-0 z-50 border-b border-white/[0.08]">
  <div class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 flex-shrink-0" title="AJUVA Š+S s.r.o.">
      <img src="/images/ajuva.png" alt="Logo AJUVA — školenia, servis" class="h-10 w-auto" />
      <span class="hidden lg:block text-white font-bold text-sm tracking-tight leading-tight">
        AJUVA<br/><span class="text-white/50 text-[11px] font-normal">Š+S s.r.o.</span>
      </span>
    </a>

    <!-- Desktop: spacer for nav (nav handles its own) -->
    <div class="flex-1"></div>

    <!-- Contact -->
    <div class="hidden lg:flex items-center gap-6 text-white/70 text-sm">
      <div class="flex items-center gap-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/40" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        <span class="font-semibold text-white">048/416 27 75</span>
      </div>
      <div class="flex items-center gap-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/40" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 7L2 7"/></svg>
        <span>ajuva@ajuva.sk</span>
      </div>
      <a href="/kontakt/ajuva" class="btn btn-primary text-sm !py-2 !px-4">
        Kontakt
      </a>
    </div>
  </div>
</header>
