---
import { companyInfo } from '../data/content';
---

<header class="bg-brand">
  <div class="max-w-6xl mx-auto px-4 py-3">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <a href="/" title="AJUVA Š+S s.r.o." class="flex-shrink-0">
        <img
          src="/images/ajuva.png"
          alt="Logo AJUVA — školenia, servis"
          class="h-12 md:h-14 w-auto"
        />
      </a>

      <!-- Contact strip -->
      <div class="hidden sm:flex items-center gap-5 text-sm text-white">
        <a href={`tel:${companyInfo.tel.replace(/\s/g, '')}`} class="flex items-center gap-1.5 hover:text-white/80 transition">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/50 flex-shrink-0" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          <span class="font-semibold">{companyInfo.tel}</span>
        </a>
        <a href={`mailto:${companyInfo.email}`} class="flex items-center gap-1.5 hover:text-white/80 transition">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/50 flex-shrink-0" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 7L2 7"/></svg>
          <span>{companyInfo.email}</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Subtle bottom line -->
  <div class="border-b border-white/10"></div>
</header>
