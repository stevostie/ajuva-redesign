---
---

<div class="header-full">
  <div class="bg-navy-900 h-1 w-full"></div>

  <div class="header-gradient py-4">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex items-center gap-4 md:gap-6">
        <!-- Logo -->
        <a href="/" title="AJUVA Š+S s.r.o." class="flex-shrink-0">
          <img
            src="/images/ajuva.png"
            alt="Logo AJUVA — školenia, servis"
            class="h-20 md:h-24 w-auto"
          />
        </a>

        <!-- Company name + tagline -->
        <div class="flex-1 min-w-0">
          <div class="font-display text-2xl md:text-3xl font-semibold text-white tracking-tight leading-tight">
            AJUVA Š+S s.r.o.
          </div>
          <div class="flex flex-wrap items-center gap-x-3 gap-y-0.5 mt-1 text-white/70 text-xs md:text-sm">
            <span>Školenia</span>
            <span class="opacity-30">·</span>
            <span>Prehliadky</span>
            <span class="opacity-30">·</span>
            <span>BOZP</span>
            <span class="opacity-30">·</span>
            <span>PO</span>
            <span class="hidden sm:inline opacity-30">·</span>
            <span class="hidden sm:inline">📍 Zvolenská cesta 20, B.Bystrica</span>
          </div>
        </div>

        <!-- Contact -->
        <div class="flex-shrink-0 text-right text-white text-sm leading-relaxed hidden sm:block">
          <div class="flex items-center justify-end gap-1.5">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/60" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            <span class="font-semibold">048/416 27 75</span>
          </div>
          <div class="flex items-center justify-end gap-1.5 mt-1">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/60" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 7L2 7"/></svg>
            <span class="text-white/80 text-xs">ajuva@ajuva.sk</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Hairline accent -->
  <div class="h-px w-full bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>
</div>
