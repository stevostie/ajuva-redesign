---
---

<div class="header-gradient relative">
  <div class="max-w-5xl mx-auto px-4 py-3">
    <div class="flex items-center gap-4">
      <!-- Logo -->
      <a href="/" title="AJUVA Š+S s.r.o." class="flex-shrink-0">
        <img
          src="/images/ajuva.png"
          alt="Logo AJUVA Š+S s.r.o."
          class="h-20 w-auto"
          style="filter: drop-shadow(0 2px 6px rgba(128,255,255,0.15));"
        />
      </a>

      <!-- Company name + tagline -->
      <div class="flex-1 text-center">
        <div class="font-heading text-xl md:text-2xl font-bold tracking-wide text-white">
          AJUVA Š+S s.r.o.
        </div>
        <div class="flex items-center justify-center gap-2 mt-1">
          <span class="text-cyan-300 text-xs">Školenia</span>
          <span class="text-cyan-400/40">·</span>
          <span class="text-cyan-300 text-xs">Prehliadky</span>
          <span class="text-cyan-400/40">·</span>
          <span class="text-cyan-300 text-xs">BOZP</span>
          <span class="text-cyan-400/40">·</span>
          <span class="text-cyan-300 text-xs">PO</span>
        </div>
        <div class="mt-1.5 flex items-center justify-center gap-2 text-xs text-cyan-200/70">
          <span>Zvolenská cesta 20, B.Bystrica</span>
          <span class="opacity-40">|</span>
          <span id="current-date"></span>
        </div>
      </div>

      <!-- Contact info -->
      <div class="flex-shrink-0 text-right text-white text-sm leading-relaxed">
        <div class="flex items-center gap-1.5 justify-end">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1.5 3.5c1.5-1 3-1.5 4.5-1.5.5 0 1 .5 1 1v3c0 .5-.5 1-1 1-1 0-2 .5-2.5 1.5s-.5 2.5 0 3.5 1.5 2 2.5 2.5 2.5.5 3.5 0 2-1.5 2.5-2.5"/></svg>
          <span class="font-semibold">048/416 27 75</span>
        </div>
        <div class="flex items-center gap-1.5 justify-end mt-0.5 text-cyan-200 text-xs">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1.5 4.5l6.5 4.5 6.5-4.5"/><rect x="1" y="3" width="14" height="10" rx="1.5"/></svg>
          <span>ajuva@ajuva.sk</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom accent line -->
  <div class="h-[2px] w-full bg-gradient-to-r from-transparent via-cyan-400/50 to-transparent"></div>
</div>

<script>
  (function() {
    const now = new Date();
    const days = ['Nedeľa','Pondelok','Utorok','Streda','Štvrtok','Piatok','Sobota'];
    const months = ['január','február','marec','apríl','máj','jún','júl','august','september','október','november','december'];
    const el = document.getElementById('current-date');
    if (el) el.textContent = `${days[now.getDay()]}, ${now.getDate()}. ${months[now.getMonth()]} ${now.getFullYear()}`;
  })();
</script>
