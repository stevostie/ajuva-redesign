---
import { galleryImages } from '../data/content';
---

<div class="card-static overflow-hidden relative" id="gallery-wrapper">
  <div class="relative w-full" style="aspect-ratio:4/3;background:var(--color-surface);" id="gallery-container">
    {galleryImages.map((img, i) => (
      <img
        src={`/${img.src}`}
        alt={img.alt}
        width={img.w}
        height={img.h}
        class="gallery-slide object-contain w-full h-full p-2 cursor-pointer"
        style={`display:${i === 0 ? 'block' : 'none'}`}
        loading={i < 3 ? 'eager' : 'lazy'}
        onclick={`this.closest('#gallery-wrapper')?.querySelector('#gallery-lightbox')?.classList.remove('hidden');document.getElementById('lb-img')?.setAttribute('src','/${img.jpg || img.src}')`}
      />
    ))}
  </div>

  <!-- Dots -->
  <div class="flex justify-center gap-2 py-3 bg-white">
    {galleryImages.map((img, i) => (
      <button class="gallery-dot w-2.5 h-2.5 rounded-full border transition-colors" data-index={i}
        style={`background:${i===0?'var(--color-accent)':'var(--color-line)'};border-color:${i===0?'var(--color-accent)':'var(--color-line-strong)'}`}
        aria-label={img.alt}
      ></button>
    ))}
  </div>

  <!-- Arrows -->
  <button id="gallery-prev" class="absolute left-3 top-[38%] -translate-y-1/2 w-10 h-10 flex items-center justify-center bg-white/95 hover:bg-white rounded-full shadow-lg transition z-10" aria-label="Predošlý obrázok" tabindex="0">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-ink)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
  </button>
  <button id="gallery-next" class="absolute right-3 top-[38%] -translate-y-1/2 w-10 h-10 flex items-center justify-center bg-white/95 hover:bg-white rounded-full shadow-lg transition z-10" aria-label="Ďalší obrázok" tabindex="0">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-ink)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
  </button>

  <!-- Lightbox -->
  <div id="gallery-lightbox" class="hidden fixed inset-0 z-[100] bg-black/95 flex items-center justify-center p-4" role="dialog" aria-label="Galéria obrázkov" onclick="this.classList.add('hidden')">
    <button class="absolute top-5 right-5 text-white/60 hover:text-white text-4xl leading-none" aria-label="Zatvoriť">&times;</button>
    <img id="lb-img" src="" alt="" class="max-w-full max-h-[90vh] object-contain rounded-lg" onclick="event.stopPropagation()" />
  </div>
</div>

<script>
  (function() {
    const wrapper = document.getElementById('gallery-wrapper');
    const container = document.getElementById('gallery-container');
    if (!container || !wrapper) return;
    const slides = container.querySelectorAll('.gallery-slide');
    const dots = wrapper.querySelectorAll('.gallery-dot');
    const prev = document.getElementById('gallery-prev');
    const next = document.getElementById('gallery-next');
    let current = 0;
    const total = slides.length;
    let autoplay = null;
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function goTo(index) {
      slides[current].style.display = 'none';
      if (dots[current]) { dots[current].style.background = 'var(--color-line)'; dots[current].style.borderColor = 'var(--color-line-strong)'; }
      current = ((index % total) + total) % total;
      slides[current].style.display = 'block';
      if (dots[current]) { dots[current].style.background = 'var(--color-accent)'; dots[current].style.borderColor = 'var(--color-accent)'; }
    }

    function nextSlide() { goTo(current + 1); }
    function prevSlide() { goTo(current - 1); }

    next?.addEventListener('click', nextSlide);
    prev?.addEventListener('click', prevSlide);
    dots?.forEach((dot) => {
      dot.addEventListener('click', () => goTo(parseInt(dot.getAttribute('data-index') || '0')));
    });

    wrapper.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') { e.preventDefault(); prevSlide(); }
      if (e.key === 'ArrowRight') { e.preventDefault(); nextSlide(); }
    });

    if (!prefersReduced) {
      autoplay = setInterval(nextSlide, 6000);
      wrapper.addEventListener('mouseenter', () => { if (autoplay) clearInterval(autoplay); });
      wrapper.addEventListener('mouseleave', () => { autoplay = setInterval(nextSlide, 6000); });
    }
  })();
</script>

<style>
  .gallery-slide { transition: opacity 0.4s; }
  @media (prefers-reduced-motion: reduce) {
    .gallery-slide { transition: none; }
  }
</style>
