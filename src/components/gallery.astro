---
import { galleryImages } from '../data/content';
---

<div class="card-static overflow-hidden" id="gallery-wrapper">
  <div class="relative w-full" style="aspect-ratio:4/3;background:var(--color-surface);" id="gallery-container">
    {galleryImages.map((img, i) => (
      <img
        src={`/${img.src}`}
        alt={img.alt}
        width={img.w}
        height={img.h}
        class={`gallery-slide object-contain w-full h-full p-2 cursor-pointer ${i === 0 ? 'active' : ''}`}
        loading={i < 3 ? 'eager' : 'lazy'}
        data-full={`/${img.src}`}
        onclick="this.closest('#gallery-wrapper')?.querySelector('#lightbox')?.classList.remove('hidden');document.getElementById('lightbox-img')?.setAttribute('src',this.dataset.full)"
      />
    ))}
  </div>

  <!-- Dots -->
  <div class="flex justify-center gap-2 py-3 bg-white">
    {galleryImages.map((_, i) => (
      <button class="w-2.5 h-2.5 rounded-full border transition-colors" data-index={i}
        style={`background:${i===0?'var(--color-accent)':'var(--color-line)'};border-color:${i===0?'var(--color-accent)':'var(--color-line-strong)'}`}
        aria-label={galleryImages[i].alt}
      ></button>
    ))}
  </div>

  <!-- Arrows -->
  <button id="gallery-prev" class="absolute left-2 top-[40%] -translate-y-1/2 w-9 h-9 flex items-center justify-center bg-white/90 hover:bg-white rounded-full shadow-md transition z-10" aria-label="Predošlý obrázok">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-ink)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
  </button>
  <button id="gallery-next" class="absolute right-2 top-[40%] -translate-y-1/2 w-9 h-9 flex items-center justify-center bg-white/90 hover:bg-white rounded-full shadow-md transition z-10" aria-label="Ďalší obrázok">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-ink)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
  </button>

  <!-- Lightbox -->
  <div id="lightbox" class="hidden fixed inset-0 z-[100] bg-black/90 flex items-center justify-center p-4" onclick="this.classList.add('hidden')">
    <button class="absolute top-4 right-4 text-white/60 hover:text-white text-3xl leading-none" aria-label="Zatvoriť">&times;</button>
    <img id="lightbox-img" src="" alt="" class="max-w-full max-h-[90vh] object-contain rounded-lg" onclick="event.stopPropagation()" />
  </div>
</div>

<script>
  (function() {
    const container = document.getElementById('gallery-container');
    if (!container) return;
    const slides = container.querySelectorAll('.gallery-slide');
    const dots = document.querySelectorAll('#gallery-wrapper button[data-index]');
    const prev = document.getElementById('gallery-prev');
    const next = document.getElementById('gallery-next');
    let current = 0;
    const total = slides.length;

    function goTo(index: number) {
      slides[current].classList.remove('active');
      if (dots[current]) { dots[current].style.background = 'var(--color-line)'; dots[current].style.borderColor = 'var(--color-line-strong)'; }
      current = ((index % total) + total) % total;
      slides[current].classList.add('active');
      if (dots[current]) { dots[current].style.background = 'var(--color-accent)'; dots[current].style.borderColor = 'var(--color-accent)'; }
    }

    next?.addEventListener('click', () => goTo(current + 1));
    prev?.addEventListener('click', () => goTo(current - 1));
    dots?.forEach((dot) => {
      dot.addEventListener('click', () => goTo(parseInt(dot.getAttribute('data-index') || '0')));
    });

    // Keyboard nav
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') goTo(current - 1);
      if (e.key === 'ArrowRight') goTo(current + 1);
    });

    setInterval(() => goTo(current + 1), 6000);
  })();
</script>
