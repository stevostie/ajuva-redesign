---
import { companyInfo } from '../data/content';
---

<footer class="bg-navy-900 text-white mt-8">
  <!-- Hairline accent -->
  <div class="h-px w-full bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

  <div class="max-w-6xl mx-auto px-4 py-8">
    <!-- Secondary links (from VIAC) -->
    <div class="text-center text-xs mb-4 flex flex-wrap justify-center gap-x-4 gap-y-1 opacity-60">
      <a href="/predpisy/bezpecnost-prace" class="hover:opacity-100 transition">Predpisy</a>
      <a href="/tlaciva/tlaciva" class="hover:opacity-100 transition">Tlačivá</a>
      <a href="/zabava/vtipy" class="hover:opacity-100 transition">Zábava</a>
      <a href="/ponukame" class="hover:opacity-100 transition">Ponúkame</a>
    </div>

    <!-- Main footer links -->
    <div class="footer-links text-center mb-5 flex flex-wrap justify-center gap-x-3 gap-y-1">
      <a href="/">DOMOV</a><span class="opacity-30">|</span>
      <a href="/skolenia/kuric-1-5-triedy">ŠKOLENIA</a><span class="opacity-30">|</span>
      <a href="/prehliadky/vtz-tlakove">PREHLIADKY</a><span class="opacity-30">|</span>
      <a href="/bozp-po/ponuka-bozp">BOZP &amp; PO</a><span class="opacity-30">|</span>
      <a href="/o-nas/profil">O NÁS</a><span class="opacity-30">|</span>
      <a href="/kontakt/ajuva">KONTAKT</a>
    </div>

    <hr class="border-white/10 mb-5" />

    <div class="text-center text-xs text-white/40 space-y-1">
      <p>Aktualizované: <span class="text-white/60 font-semibold">{companyInfo.lastUpdated}</span></p>
      <p>&copy; {new Date().getFullYear()} AJUVA Š+S s.r.o. — Všetky práva vyhradené.</p>
      <p class="text-white/30">Zvolenská cesta 20, 974 01 Banská Bystrica | {companyInfo.tel} | {companyInfo.email}</p>
    </div>
  </div>
</footer>
