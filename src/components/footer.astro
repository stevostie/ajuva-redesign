    <div class="text-center text-xs text-cyan-200 space-y-1">
      <p>Aktualizované dňa: <strong>{companyInfo.lastUpdated}</strong></p>
      <p>&copy; {new Date().getFullYear()} AJUVA Š+S s.r.o. — Všetky práva vyhradené.</p>
      <p class="opacity-60">
        Zvolenská cesta 20, 974 01 Banská Bystrica | Tel: {companyInfo.tel} | {companyInfo.email}
      </p>
    </div>
  </div>
</footer>
