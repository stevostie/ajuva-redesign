---
import { companyInfo } from '../data/content';
---

<footer class="footer pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid md:grid-cols-4 gap-10 pb-12 border-b border-white/[0.06]">
      <!-- Company -->
      <div>
        <h4 class="mb-4">AJUVA Š+S s.r.o.</h4>
        <p class="text-ink-300 text-sm leading-relaxed">Odborné školenia, prehliadky a revízie vyhradených technických zariadení. BOZP, PO, pracovná zdravotná služba.</p>
        <p class="text-ink-300 text-xs mt-3">© {new Date().getFullYear()} Všetky práva vyhradené.</p>
      </div>
      <!-- Quick links 1 -->
      <div>
        <h4 class="mb-4">Služby</h4>
        <div class="space-y-2.5">
          <a href="/skolenia/kuric-1-5-triedy" class="block">Školenia</a>
          <a href="/prehliadky/vtz-tlakove" class="block">Prehliadky</a>
          <a href="/bozp-po/ponuka-bozp" class="block">BOZP, PO</a>
          <a href="/o-nas/profil" class="block">O nás</a>
          <a href="/kontakt/ajuva" class="block">Kontakt</a>
        </div>
      </div>
      <!-- Quick links 2 -->
      <div>
        <h4 class="mb-4">Informácie</h4>
        <div class="space-y-2.5">
          <a href="/predpisy/bezpecnost-prace" class="block">Predpisy</a>
          <a href="/tlaciva/tlaciva" class="block">Tlačivá</a>
          <a href="/zabava/vtipy" class="block">Zábava</a>
          <a href="/ponukame" class="block">Ponúkame</a>
        </div>
      </div>
      <!-- Contact -->
      <div>
        <h4 class="mb-4">Kontakt</h4>
        <div class="space-y-3 text-sm text-ink-300">
          <p>Zvolenská cesta 20<br/>974 01 Banská Bystrica</p>
          <p class="font-semibold text-white">{companyInfo.tel}</p>
          <p>{companyInfo.email}</p>
        </div>
      </div>
    </div>
    <div class="pt-6 flex flex-col md:flex-row justify-between items-center gap-3 text-xs text-ink-500">
      <p>Aktualizované: {companyInfo.lastUpdated}</p>
      <p>IČO: {companyInfo.ico} · DIČ: {companyInfo.dic} · IČ DPH: {companyInfo.icDph}</p>
    </div>
  </div>
</footer>
