---
import { companyInfo } from '../data/content';
---

<footer class="bg-navy text-white mt-8">
  <!-- Bottom accent line -->
  <div class="bg-accent h-0.5 w-full opacity-60"></div>

  <div class="max-w-5xl mx-auto px-4 py-6">
    <!-- Footer link bar (matches original) -->
    <div class="footer-links text-center text-sm space-x-2 mb-4 flex flex-wrap justify-center gap-x-3 gap-y-1">
      <a href="/">DOMOV</a><span class="opacity-50">|</span>
      <a href="/skolenia/kuric-1-5-triedy">ŠKOLENIA</a><span class="opacity-50">|</span>
      <a href="/prehliadky/vtz-tlakove">PREHLIADKY</a><span class="opacity-50">|</span>
      <a href="/bozp-po/ponuka-bozp">BOZP, PO</a><span class="opacity-50">|</span>
      <a href="/predpisy/bezpecnost-prace">PREDPISY</a><span class="opacity-50">|</span>
      <a href="/kontakt/ajuva">KONTAKT</a><span class="opacity-50">|</span>
      <a href="/o-nas/profil">O NÁS</a><span class="opacity-50">|</span>
      <a href="/tlaciva/tlaciva">TLAČIVÁ</a><span class="opacity-50">|</span>
