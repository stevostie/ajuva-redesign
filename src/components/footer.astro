---
import { companyInfo } from '../data/content';
---

<footer class="bg-navy-900 text-white mt-0">
  <div class="max-w-6xl mx-auto px-4 py-10">
    <!-- Secondary links (from navigation "Viac" group) -->
    <div class="footer-links text-center mb-6 flex flex-wrap justify-center gap-x-5 gap-y-2">
      <a href="/predpisy/bezpecnost-prace">PREDPISY</a>
      <a href="/tlaciva/tlaciva">TLAČIVÁ</a>
      <a href="/zabava/vtipy">ZÁBAVA</a>
      <a href="/ponukame">PONÚKAME</a>
      <a href="/imsitemap.html" class="opacity-40">Mapa stránky</a>
    </div>

    <hr class="border-white/10 mb-6" />

    <!-- Main links -->
    <div class="footer-links text-center text-sm mb-6 flex flex-wrap justify-center gap-x-3 gap-y-1">
      <a href="/">Domov</a><span class="opacity-30">|</span>
      <a href="/skolenia/kuric-1-5-triedy">Školenia</a><span class="opacity-30">|</span>
      <a href="/prehliadky/vtz-tlakove">Prehliadky</a><span class="opacity-30">|</span>
      <a href="/bozp-po/ponuka-bozp">BOZP, PO</a><span class="opacity-30">|</span>
      <a href="/kontakt/ajuva">Kontakt</a><span class="opacity-30">|</span>
      <a href="/o-nas/profil">O nás</a>
    </div>

    <div class="text-center text-xs text-white/40 space-y-1">
      <p>Aktualizované: <strong class="text-white/60">{companyInfo.lastUpdated}</strong></p>
      <p>&copy; {new Date().getFullYear()} AJUVA Š+S s.r.o. — Všetky práva vyhradené.</p>
      <p>Zvolenská cesta 20, 974 01 Banská Bystrica · {companyInfo.tel} · {companyInfo.email}</p>
    </div>
  </div>
</footer>
