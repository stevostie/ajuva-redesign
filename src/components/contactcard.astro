---
import { companyInfo } from '../data/content';
---

<div class="card-static p-8 md:p-10 flex flex-col">
  <h3 class="text-2xl font-black text-ink mb-2">Kontaktné údaje</h3>
  <p class="text-ink-500 text-sm mb-8">Ozvite sa — poradíme, naplánujeme, vybavíme.</p>

  <div class="space-y-5 mb-8">
    <div class="flex items-center gap-4">
      <div class="w-10 h-10 rounded-xl bg-red-light flex items-center justify-center flex-shrink-0">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-red)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
      </div>
      <div>
        <p class="text-ink-300 text-[11px] font-bold uppercase tracking-wider mb-0.5">Adresa</p>
        <p class="text-ink font-semibold text-sm">{companyInfo.address}</p>
      </div>
    </div>

    <div class="flex items-center gap-4">
      <div class="w-10 h-10 rounded-xl bg-red-light flex items-center justify-center flex-shrink-0">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-red)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
      </div>
      <div>
        <p class="text-ink-300 text-[11px] font-bold uppercase tracking-wider mb-0.5">Telefón</p>
        <a href={`tel:${companyInfo.tel.replace(/\s/g,'')}`} class="text-ink font-semibold text-sm hover:text-red transition-colors">{companyInfo.tel}</a>
      </div>
    </div>

    <div class="flex items-center gap-4">
      <div class="w-10 h-10 rounded-xl bg-red-light flex items-center justify-center flex-shrink-0">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-red)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      </div>
      <div>
        <p class="text-ink-300 text-[11px] font-bold uppercase tracking-wider mb-0.5">E-mail</p>
        <a href={`mailto:${companyInfo.email}`} class="text-ink font-semibold text-sm hover:text-red transition-colors">{companyInfo.email}</a>
      </div>
    </div>
  </div>

  <a href="/kontakt/ajuva" class="btn btn-primary w-full !rounded-xl mt-auto">Napísať správu →</a>
</div>
