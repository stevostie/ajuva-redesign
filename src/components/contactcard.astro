---
import { companyInfo } from '../data/content';
---

<div class="card p-5">
  <!-- Insurance data -->
  <h3 class="font-sans text-lg font-semibold text-ink text-center mb-4">Fakturačné údaje</h3>

  <div class="text-center text-sm text-ink space-y-1">
    <p class="font-semibold text-navy-900">AJUVA Š+S s.r.o.</p>
    <p class="text-muted">Zvolenská cesta 20, 974 01 Banská Bystrica</p>
    <div class="mt-3 grid grid-cols-2 gap-2 text-xs">
      <div class="bg-surface rounded-lg py-1.5 px-2">
        <span class="text-muted">IČO</span>
        <p class="font-semibold text-ink">{companyInfo.ico}</p>
      </div>
      <div class="bg-surface rounded-lg py-1.5 px-2">
        <span class="text-muted">DIČ</span>
        <p class="font-semibold text-ink">{companyInfo.dic}</p>
      </div>
      <div class="bg-surface rounded-lg py-1.5 px-2 col-span-2">
        <span class="text-muted">IČ DPH</span>
        <p class="font-semibold text-ink">{companyInfo.icDph}</p>
      </div>
    </div>
    <p class="text-xs text-muted mt-2">Zápis OR OS B.Bystrica, odd. Sro, vložka č.10331/S</p>
    <p class="mt-2 font-semibold text-navy-700">{companyInfo.tel}</p>
    <p class="text-xs">{companyInfo.email}</p>
  </div>

  <hr class="hairline my-4" />

  <!-- Contacts -->
  <h3 class="font-sans text-base font-semibold text-ink text-center mb-2">Kontakty</h3>
  <p class="text-xs text-muted text-center mb-3">(zameranie na oblasti služieb, viď. KONTAKT)</p>

  <div class="space-y-2.5">
    {companyInfo.contacts.map((contact) => (
      <div class="bg-surface rounded-lg p-3 text-center text-sm">
        <p class="font-semibold text-navy-900">{contact.name}</p>
        <p class="text-xs text-muted mt-0.5">{contact.email}</p>
        <p class="text-xs text-muted">tel.: {contact.tel}</p>
      </div>
    ))}
  </div>

  <hr class="hairline my-4" />

  <!-- Building photo -->
  <div class="flex justify-center">
    <img
      src="/images/image002.jpg"
      alt="Budova spoločnosti AJUVA, Zvolenská cesta 20, Banská Bystrica"
      class="rounded-card border border-line w-full max-w-[260px]"
      loading="lazy"
    />
  </div>
</div>
