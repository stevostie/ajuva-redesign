---
import { companyInfo } from '../data/content';
---

<div class="card-static p-6 md:p-8">
  <div class="flex items-center gap-3 mb-6">
    <div class="w-10 h-10 rounded-xl bg-brand/10 flex items-center justify-center text-brand">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
    </div>
    <div>
      <h3 class="font-bold text-ink text-lg">Kontaktné údaje</h3>
      <p class="text-ink-500 text-xs">Fakturačné a kontaktné informácie</p>
    </div>
  </div>

  <div class="bg-surface rounded-xl p-5 mb-5">
    <p class="font-extrabold text-ink text-lg mb-1">{companyInfo.name}</p>
    <p class="text-ink-500 text-sm">Zvolenská cesta 20, 974 01 Banská Bystrica</p>
    <div class="flex flex-wrap gap-x-6 gap-y-1 mt-3 text-sm">
      <span class="text-ink-500">IČO: <strong class="text-ink">{companyInfo.ico}</strong></span>
      <span class="text-ink-500">DIČ: <strong class="text-ink">{companyInfo.dic}</strong></span>
      <span class="text-ink-500">IČ DPH: <strong class="text-ink">{companyInfo.icDph}</strong></span>
    </div>
    <p class="text-ink-300 text-xs mt-2">Zápis OR OS B.Bystrica, odd. Sro, vložka č.10331/S</p>
  </div>

  <div class="space-y-3 mb-5">
    {companyInfo.contacts.map((contact) => (
      <div class="flex items-start gap-3 p-3 rounded-xl bg-surface/50">
        <div class="w-8 h-8 rounded-lg bg-white flex items-center justify-center flex-shrink-0 border border-line">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <div>
          <p class="font-bold text-ink text-sm">{contact.name}</p>
          <p class="text-ink-500 text-xs">{contact.email}</p>
          <p class="text-ink-500 text-xs mt-0.5 flex items-center gap-1">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            {contact.tel}
          </p>
        </div>
      </div>
    ))}
  </div>

  <div class="flex items-center gap-3 mb-5 px-3">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-ink-300)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
    <span class="text-ink font-semibold text-sm">{companyInfo.tel}</span>
  </div>

  <img src="/images/image002.webp" alt="Budova spoločnosti AJUVA Š+S s.r.o., Zvolenská cesta 20, Banská Bystrica" width="600" height="400" class="w-full rounded-xl border border-line" loading="lazy" />
</div>
