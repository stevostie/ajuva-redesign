---
import { companyInfo } from '../data/content';
---

<div class="card p-6 space-y-5">
  <!-- Invoice details -->
  <div>
    <p class="eyebrow">Fakturačné údaje</p>
    <div class="text-sm text-ink mt-2 space-y-0.5">
      <p class="font-semibold text-navy-900">AJUVA Š+S s.r.o.</p>
      <p>Zvolenská cesta 20, 974 01 Banská Bystrica</p>
      <p class="mt-1">IČO: <strong>{companyInfo.ico}</strong> · DIČ: <strong>{companyInfo.dic}</strong></p>
      <p>IČ DPH: <strong>{companyInfo.icDph}</strong></p>
      <p class="text-xs text-muted mt-1">Zápis OR OS B.Bystrica, odd. Sro, vložka č.10331/S</p>
    </div>
  </div>

  <hr class="hairline" />

  <!-- Contacts -->
  <div>
    <p class="eyebrow">Kontakty</p>
    <p class="text-xs text-muted mt-1">(zameranie na oblasti služieb — viď. KONTAKT)</p>
    {companyInfo.contacts.map((contact) => (
      <div class="mt-3 p-3 bg-surface rounded-card border border-line">
        <p class="font-semibold text-navy-900 text-sm">{contact.name}</p>
        <p class="text-xs text-muted">{contact.email}</p>
        <p class="text-xs text-muted">tel.: {contact.tel}</p>
      </div>
    ))}
    <p class="mt-2 text-sm font-semibold text-navy-900">tel./fax: {companyInfo.tel}</p>
    <p class="text-sm">{companyInfo.email}</p>
  </div>

  <hr class="hairline" />

  <!-- Building photo -->
  <img
    src="/images/image002.jpg"
    alt="Budova spoločnosti AJUVA Š+S s.r.o., Zvolenská cesta 20, Banská Bystrica"
    class="w-full rounded-card border border-line"
    loading="lazy"
  />
</div>
