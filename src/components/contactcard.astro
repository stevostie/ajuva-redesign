---
import { companyInfo } from '../data/content';
---

<div class="card space-y-5 !p-0 overflow-hidden">
  <!-- Address block -->
  <div class="p-6 pb-0">
    <p class="text-xs font-semibold text-muted uppercase tracking-wider mb-2">Fakturačné údaje</p>
    <div class="text-sm space-y-0.5">
      <p class="font-semibold text-ink">AJUVA Š+S s.r.o.</p>
      <p class="text-muted">Zvolenská cesta 20, 974 01 Banská Bystrica</p>
      <p class="text-muted mt-1">IČO: <span class="text-ink font-semibold">{companyInfo.ico}</span> · DIČ: <span class="text-ink font-semibold">{companyInfo.dic}</span></p>
      <p class="text-muted">IČ DPH: <span class="text-ink font-semibold">{companyInfo.icDph}</span></p>
      <p class="text-muted text-xs mt-1">Zápis OR OS B.Bystrica, odd. Sro, vložka č.10331/S</p>
    </div>
  </div>

  <hr class="hairline" />

  <!-- Contacts -->
  <div class="px-6">
    <p class="text-xs font-semibold text-muted uppercase tracking-wider mb-3">Kontakty</p>
    {companyInfo.contacts.map((contact) => (
      <div class="flex gap-3 mb-3 last:mb-0">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mt-0.5" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        <div>
          <p class="font-semibold text-ink text-sm">{contact.name}</p>
          <p class="text-muted text-xs">{contact.tel}</p>
          <p class="text-muted text-xs">{contact.email}</p>
        </div>
      </div>
    ))}
    <div class="mt-3 pt-3 border-t border-line">
      <p class="text-sm font-semibold text-ink">tel./fax: {companyInfo.tel}</p>
      <p class="text-sm text-muted">{companyInfo.email}</p>
    </div>
  </div>

  <hr class="hairline" />

  <!-- Building photo -->
  <div class="px-6 pb-6">
    <img
      src="/images/image002.jpg"
      alt="Budova spoločnosti AJUVA Š+S s.r.o., Zvolenská cesta 20, Banská Bystrica"
      class="w-full rounded-card border border-line"
      loading="lazy"
    />
  </div>
</div>
