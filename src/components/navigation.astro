---
import { mainMenu } from '../data/menu';

const currentPath = Astro.url?.pathname || '/';
---

<!-- Mobile toggle button -->
<button
  id="mobile-menu-toggle"
  class="nav-mobile-toggle w-full bg-navy text-white px-4 py-3 text-left font-bold flex items-center justify-between md:hidden"
  aria-label="Menu"
>
  <span>☰ MENU</span>
  <span id="mobile-arrow" class="transition-transform duration-300">▼</span>
</button>

<!-- Desktop Navigation — 2026 3D Style -->
<nav class="nav-desktop bg-gradient-to-b from-[#000044] via-[#000066] to-[#000088] text-white shadow-2xl border-b-2 border-accent/30 relative z-40">
  <div class="max-w-5xl mx-auto px-2">
    <ul class="flex flex-wrap justify-center py-1">
      {mainMenu.map((item) => (
        <li class="relative group perspective-[800px]">
          {item.href ? (
            <a
              href={item.href}
              class={`nav-item block px-3 py-3 text-[13px] font-bold whitespace-nowrap rounded-lg mx-0.5 tracking-wide transition-all duration-300 ${
                currentPath === item.href
                  ? 'nav-active bg-cyan-400/20 text-cyan-300 shadow-[0_0_15px_rgba(128,255,255,0.3)] scale-105'
                  : 'hover:bg-white/5 hover:text-cyan-200 hover:scale-105'
              }`}
            >
              {item.label}
            </a>
          ) : (
            <span
              class={`nav-item block px-3 py-3 text-[13px] font-bold whitespace-nowrap rounded-lg mx-0.5 tracking-wide cursor-pointer transition-all duration-300 ${
                item.children?.some(c => currentPath === c.href)
                  ? 'nav-active bg-cyan-400/20 text-cyan-300 shadow-[0_0_15px_rgba(128,255,255,0.3)] scale-105'
                  : 'group-hover:bg-white/5 group-hover:text-cyan-200 group-hover:scale-105'
              }`}
            >
              {item.label}
              <span class="ml-1 text-[10px] opacity-50 group-hover:opacity-100 transition-opacity">▾</span>
            </span>
          )}
          {item.children && item.children.length > 0 && (
            <ul class="nav-dropdown-3d absolute left-1/2 -translate-x-1/2 top-full mt-1 min-w-[220px]
                       opacity-0 invisible group-hover:opacity-100 group-hover:visible
                       transition-all duration-300 z-50
                       bg-gradient-to-b from-[#000066]/98 via-[#000055]/98 to-[#000044]/98
                       backdrop-blur-xl
                       rounded-xl border border-cyan-400/20
                       shadow-[0_20px_50px_rgba(0,0,0,0.5),0_0_30px_rgba(128,255,255,0.1)]
                       transform-gpu translate-y-2 group-hover:translate-y-0">
              {item.children.map((child, idx) => (
                <li style={`animation: dropdown-in 0.3s ease-out ${idx * 0.04}s both`}>
                  <a
                    href={child.href}
                    class={`block px-5 py-2.5 text-sm whitespace-nowrap transition-all duration-200
                      ${idx === 0 ? 'rounded-t-xl' : ''}
                      ${idx === item.children.length - 1 ? 'rounded-b-xl' : ''}
                      ${currentPath === child.href
                        ? 'bg-cyan-400/15 text-cyan-300 font-semibold'
                        : 'hover:bg-white/10 hover:text-cyan-200 hover:pl-6'
                      }`}
                  >
                    <span class="mr-2 opacity-40 text-cyan-300">▸</span>
                    {child.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </div>
</nav>

<!-- Mobile menu (hidden by default) -->
<div id="mobile-menu" class="nav-mobile-menu bg-gradient-to-b from-[#000044] to-navy text-white hidden md:hidden">
  <ul class="divide-y divide-cyan-400/10">
    {mainMenu.map((item) => (
      <li>
        {item.href ? (
          <a href={item.href} class="block px-4 py-3 text-sm font-bold hover:bg-cyan-400/10 hover:text-cyan-200 active:scale-[0.98] transition-all">
            {item.label}
          </a>
        ) : (
          <details class="group/mob">
            <summary class="block px-4 py-3 text-sm font-bold cursor-pointer hover:bg-cyan-400/10 hover:text-cyan-200 list-none flex justify-between items-center">
              {item.label}
              <span class="text-[10px] opacity-50 group-open/mob:rotate-180 transition-transform">▾</span>
            </summary>
            <ul class="bg-[#000033]/60 backdrop-blur-sm">
              {item.children?.map((child) => (
                <li>
                  <a href={child.href} class="block px-8 py-2.5 text-sm hover:bg-cyan-400/10 hover:text-cyan-200 active:scale-[0.98] transition-all">
                    ▸ {child.label}
                  </a>
                </li>
              ))}
            </ul>
          </details>
        )}
      </li>
    ))}
  </ul>
</div>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const arrow = document.getElementById('mobile-arrow');
  if (toggle && menu && arrow) {
    toggle.addEventListener('click', () => {
      const isHidden = menu.classList.contains('hidden');
      menu.classList.toggle('hidden', !isHidden);
      arrow.style.transform = isHidden ? 'rotate(180deg)' : 'rotate(0deg)';
    });
  }
</script>
