---
import { mainMenu } from '../data/menu';

const currentPath = Astro.url?.pathname || '/';
---

<!-- Mobile toggle button -->
<button
  id="mobile-menu-toggle"
  class="nav-mobile-toggle w-full bg-navy text-white px-4 py-3 text-left font-bold flex items-center justify-between"
  aria-label="Menu"
>
  <span>☰ MENU</span>
  <span id="mobile-arrow" class="transition-transform duration-300">▼</span>
</button>

<!-- Desktop Navigation — clean modern -->
<nav class="nav-desktop text-white shadow-md relative z-40 border-b border-white/10">
  <div class="max-w-5xl mx-auto">
    <ul class="flex flex-wrap justify-center">
      {mainMenu.map((item) => (
        <li class="relative group">
          {item.href ? (
            <a
              href={item.href}
              class={`nav-item block px-4 py-3 text-[13px] font-semibold whitespace-nowrap tracking-wide ${currentPath === item.href ? 'nav-active' : ''}`}
            >
              {item.label}
            </a>
          ) : (
            <span
              class={`nav-item block px-4 py-3 text-[13px] font-semibold whitespace-nowrap tracking-wide cursor-pointer ${item.children?.some(c => c.href && currentPath === c.href) ? 'nav-active' : ''}`}
            >
              {item.label}
              <span class="ml-1 text-[10px] opacity-60">▾</span>
            </span>
          )}
          {item.children && item.children.length > 0 && (
            <ul class="absolute left-1/2 -translate-x-1/2 top-full pt-1 min-w-[220px]
                       opacity-0 invisible group-hover:opacity-100 group-hover:visible
                       transition-all duration-200 z-50
                       bg-navy/98 backdrop-blur-sm
                       rounded-lg border border-white/10
                       shadow-lg shadow-black/30
                       translate-y-1 group-hover:translate-y-0">
              {item.children.map((child, idx) => (
                child.isSectionHeader ? (
                  <li class="px-5 pt-3 pb-1 text-[11px] font-bold text-cyan-300/60 uppercase tracking-wider">
                    {child.label}
                  </li>
                ) : (
                  <li class={idx === 0 || item.children[idx - 1]?.isSectionHeader ? 'mt-0' : ''}>
                    <a
                      href={child.href}
                      class={`block px-5 py-2 text-sm whitespace-nowrap transition-colors duration-150
                        ${currentPath === child.href
                          ? 'bg-white/10 text-orange-400 font-semibold'
                          : 'hover:bg-white/10 hover:text-cyan-200'
                        }`}
                    >
                      {child.label}
                    </a>
                  </li>
                )
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </div>
</nav>

<!-- Mobile menu (hidden by default) -->
<div id="mobile-menu" class="nav-mobile-menu bg-navy text-white hidden">
  <ul class="divide-y divide-white/10">
    {mainMenu.map((item) => (
      <li>
        {item.href ? (
          <a href={item.href} class="block px-4 py-3 text-sm font-semibold hover:bg-white/10 hover:text-cyan-200 transition-colors">
            {item.label}
          </a>
        ) : (
          <details class="group/mob">
            <summary class="block px-4 py-3 text-sm font-semibold cursor-pointer hover:bg-white/10 hover:text-cyan-200 list-none flex justify-between items-center">
              {item.label}
              <span class="text-[10px] opacity-50 group-open/mob:rotate-180 transition-transform">▾</span>
            </summary>
            <ul class="bg-[#000033]/60">
              {item.children?.map((child) => (
                child.isSectionHeader ? (
                  <li class="px-8 pt-3 pb-1 text-[11px] font-bold text-cyan-300/50 uppercase">{child.label}</li>
                ) : (
                  <li>
                    <a href={child.href} class="block px-8 py-2.5 text-sm hover:bg-white/10 hover:text-cyan-200 transition-colors">
                      {child.label}
                    </a>
                  </li>
                )
              ))}
            </ul>
          </details>
        )}
      </li>
    ))}
  </ul>
</div>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const arrow = document.getElementById('mobile-arrow');
  if (toggle && menu && arrow) {
    toggle.addEventListener('click', () => {
      const isHidden = menu.classList.contains('hidden');
      menu.classList.toggle('hidden', !isHidden);
      arrow.style.transform = isHidden ? 'rotate(180deg)' : 'rotate(0deg)';
    });
  }
</script>
