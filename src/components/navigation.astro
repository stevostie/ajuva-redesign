---
import { mainMenu } from '../data/menu';
const currentPath = Astro.url?.pathname || '/';
---

<!-- Mobile -->
<button id="mobile-menu-toggle" class="nav-mobile-toggle w-full bg-primary text-white px-4 py-3 text-sm font-semibold items-center justify-between" aria-label="Menu">
  <span>☰ Menu</span>
  <span id="mobile-arrow" class="text-[10px] transition-transform duration-300">▾</span>
</button>

<nav class="nav-desktop border-b border-white/[0.06] shadow-sm">
  <div class="max-w-7xl mx-auto px-4">
    <ul class="flex items-center">
      {mainMenu.map((item) => (
        <li class="relative group">
          {item.href ? (
            <a href={item.href} class={`nav-item block px-4 py-3.5 whitespace-nowrap ${currentPath === item.href ? 'nav-active' : ''}`}>
              {item.label}
            </a>
          ) : (
            <button class={`nav-item block px-4 py-3.5 whitespace-nowrap inline-flex items-center gap-1 ${item.children?.some(c => c.href && currentPath === c.href) ? 'nav-active' : ''}`}>
              {item.label}
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="opacity-50 group-hover:opacity-100 transition-opacity" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
          )}
          {item.children && item.children.length > 0 && (
            <div class="absolute left-0 top-full pt-1 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
              <div class="nav-dropdown">
                {item.children.map((child) => (
                  child.isSectionHeader ? (
                    <div class="nav-dropdown-section">{child.label}</div>
                  ) : (
                    <a href={child.href} class={`nav-dropdown-item ${currentPath === child.href ? 'text-accent font-semibold bg-accent-50' : ''}`}>
                      {child.label}
                    </a>
                  )
                ))}
              </div>
            </div>
          )}
        </li>
      ))}
    </ul>
  </div>
</nav>

<!-- Mobile menu -->
<div id="mobile-menu" class="nav-mobile-menu bg-brand text-white hidden">
  <ul class="divide-y divide-white/[0.06]">
    {mainMenu.map((item) => (
      <li>
        {item.href ? (
          <a href={item.href} class="block px-5 py-3 text-sm font-semibold hover:bg-white/5 transition-colors">{item.label}</a>
        ) : (
          <details>
            <summary class="block px-5 py-3 text-sm font-semibold hover:bg-white/5 transition-colors cursor-pointer list-none flex justify-between items-center">
              {item.label} <span class="text-[10px]">▾</span>
            </summary>
            <div class="bg-black/20 py-1">
              {item.children?.map((child) => (
                child.isSectionHeader ? (
                  <div class="px-8 py-2 text-[11px] font-bold text-white/30 uppercase">{child.label}</div>
                ) : (
                  <a href={child.href} class="block px-8 py-2.5 text-sm hover:bg-white/5 transition-colors">{child.label}</a>
                )
              ))}
            </div>
          </details>
        )}
      </li>
    ))}
  </ul>
</div>

<script>
  const t = document.getElementById('mobile-menu-toggle');
  const m = document.getElementById('mobile-menu');
  const a = document.getElementById('mobile-arrow');
  if (t && m && a) {
    t.addEventListener('click', () => {
      m.classList.toggle('hidden');
      a.style.transform = m.classList.contains('hidden') ? 'rotate(0deg)' : 'rotate(180deg)';
    });
  }
</script>
